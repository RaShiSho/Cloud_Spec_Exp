# Copy this file to .env and fill real values.

# LLM API keys. Fill only the providers you use.
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# OpenAI-compatible endpoint settings for DeepSeek.
OPENAI_API_BASE=https://api.deepseek.com
OPENAI_BASE_URL=https://api.deepseek.com

# mini-SWE-agent defaults.
MSWEA_MODEL_NAME=deepseek/deepseek-chat
MSWEA_COST_TRACKING=ignore_errors

# Optional pip mirror settings for WSL setup.
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_DEFAULT_TIMEOUT=120
