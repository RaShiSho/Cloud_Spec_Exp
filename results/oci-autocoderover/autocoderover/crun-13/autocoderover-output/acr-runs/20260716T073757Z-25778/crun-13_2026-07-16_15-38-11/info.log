56 void
57 cleanup_freep (void *p)
58 {
59   void **pp = (void **) p;
60   free (*pp);
61 }
62 
63 void
64 cleanup_filep (FILE **f)
65 {
66   FILE *file = *f;
67   if (file)
68     (void) fclose (file);
69 }
70 
71 void
72 cleanup_closep (void *p)
73 {
74   int *pp = p;
75   if (*pp >= 0)
76     close (*pp);
77 }
78 
79 void
80 cleanup_close_vecp (int **p)
81 {
82   int *pp = *p;
83   int i;
84 
85   for (i = 0; pp[i] >= 0; i++)
86     close (pp[i]);
87 }
