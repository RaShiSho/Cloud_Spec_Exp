854 static int
855 write_container_status (libcrun_container_t *container, libcrun_context_t *context, pid_t pid,
856                         char *cgroup_path, char *created, libcrun_error_t *err)
857 {
858   cleanup_free char *cwd = get_current_dir_name ();
