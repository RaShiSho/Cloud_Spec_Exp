913 int
914 set_blocking_fd (int fd, int blocking, libcrun_error_t *err)
915 {
916   int ret, flags = fcntl (fd, F_GETFL, 0);
917   if (UNLIKELY (flags < 0))
918     return crun_make_error (err, errno, "fcntl");
919 
920   ret = fcntl (fd, F_SETFL, blocking ? flags & ~O_NONBLOCK : flags | O_NONBLOCK);
921   if (UNLIKELY (ret < 0))
922     return crun_make_error (err, errno, "fcntl");
923   return 0;
924 }
