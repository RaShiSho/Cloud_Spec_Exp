899 void
900 get_current_timestamp (char *out)
901 {
902   struct timeval tv;
903   struct tm now;
904   char timestamp[64];
905 
906   gettimeofday (&tv, NULL);
907   gmtime_r (&tv.tv_sec, &now);
908   strftime (timestamp, sizeof (timestamp), "%Y-%m-%dT%H:%M:%S", &now);
