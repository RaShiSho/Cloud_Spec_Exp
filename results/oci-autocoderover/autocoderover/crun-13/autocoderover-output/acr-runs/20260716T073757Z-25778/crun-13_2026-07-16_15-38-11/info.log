377 static libcrun_container_t *
378 make_container (oci_container *container_def)
379 {
380   libcrun_container_t *container = xmalloc (sizeof (*container));
381   memset (container, 0, sizeof (*container));
382   container->container_def = container_def;
383 
384   container->host_uid = getuid ();
385   container->host_gid = getgid ();
386 
387   return container;
388 }
