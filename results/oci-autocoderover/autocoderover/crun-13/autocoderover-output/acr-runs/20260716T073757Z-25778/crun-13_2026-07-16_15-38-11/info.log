43 int
44 close_and_reset (int *fd)
45 {
46   int ret = 0;
47   if (*fd >= 0)
48     {
49       ret = close (*fd);
50       if (LIKELY (ret == 0))
51         *fd = -1;
52     }
53   return ret;
54 }
