840   cleanup_container_status libcrun_container_status_t status;
841 
842   memset (&status, 0, sizeof (status));
843 
844   ret = libcrun_read_container_status (&status, state_root, id, err);
845   if (UNLIKELY (ret < 0))
846     return ret;
847 
848   ret = kill (status.pid, signal);
849   if (UNLIKELY (ret < 0))
850     return crun_make_error (err, errno, "kill container");
851   return 0;
852 }
