390 libcrun_container_t *
391 libcrun_container_load_from_memory (const char *json, libcrun_error_t *err)
392 {
393   oci_container *container_def;
394   cleanup_free char *oci_error = NULL;
395   container_def = oci_container_parse_data (json, NULL, &oci_error);
396   if (container_def == NULL)
397     {
398       crun_make_error (err, 0, "load: %s", oci_error);
399       return NULL;
400     }
401   return make_container (container_def);
402 }
