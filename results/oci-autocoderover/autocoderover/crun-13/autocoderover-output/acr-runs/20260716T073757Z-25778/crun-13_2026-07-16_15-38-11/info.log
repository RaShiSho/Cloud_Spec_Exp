162 int
163 write_file_at (int dirfd, const char *name, const void *data, size_t len, libcrun_error_t *err)
164 {
165   cleanup_close int fd = openat (dirfd, name, O_WRONLY | O_CREAT, 0700);
166   int ret = 0;
167   if (UNLIKELY (fd < 0))
168     return crun_make_error (err, errno, "writing file '%s'", name);
169 
170   if (len)
171     {
172       ret = write (fd, data, len);
173       if (UNLIKELY (ret < 0))
174         return crun_make_error (err, errno, "writing file '%s'", name);
175     }
176 
177   return ret;
178 }
