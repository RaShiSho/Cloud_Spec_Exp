278 int
279 crun_ensure_file (const char *path, int mode, libcrun_error_t *err)
280 {
281   cleanup_free char *tmp = xstrdup (path);
282   size_t len = strlen (tmp);
283   char *it = tmp + len - 1;
284   int ret;
285 
286   while (*it != '/' && it > tmp)
287     it--;
288   if (it > tmp)
289     {
290       *it = '\0';
291       ret = crun_ensure_directory (tmp, mode, err);
292       if (UNLIKELY (ret < 0))
293         return ret;
294       *it = '/';
295 
296       return create_file_if_missing (tmp, err);
297     }
298   return 0;
299 }
