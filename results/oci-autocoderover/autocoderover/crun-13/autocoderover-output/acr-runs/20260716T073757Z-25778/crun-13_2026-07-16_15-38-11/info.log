2028     return ret;
2029 
2030   ret = libcrun_is_container_running (&status, err);
2031   if (UNLIKELY (ret < 0))
2032     return ret;
2033   if (ret == 0)
2034     return crun_make_error (err, errno, "the container %s is not running", id);
2035 
2036   return libcrun_container_pause_linux (&status, id, err);
2037 }
