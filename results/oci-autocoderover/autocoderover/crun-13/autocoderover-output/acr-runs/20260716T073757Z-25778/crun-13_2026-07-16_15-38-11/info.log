470   struct cmsghdr *cmsg = NULL;
471   struct iovec iov[1];
472   struct msghdr msg;
473   char ctrl_buf[CMSG_SPACE (sizeof (int))];
474   char data[1];
475 
476   memset (&msg, 0, sizeof (struct msghdr));
477   memset (ctrl_buf, 0, CMSG_SPACE (sizeof (int)));
478 
479   data[0] = ' ';
480   iov[0].iov_base = data;
481   iov[0].iov_len = sizeof (data);
482 
483   msg.msg_name = NULL;
484   msg.msg_namelen = 0;
485   msg.msg_iov = iov;
486   msg.msg_iovlen = 1;
487   msg.msg_controllen = CMSG_SPACE (sizeof (int));
488   msg.msg_control = ctrl_buf;
489 
490   cmsg = CMSG_FIRSTHDR (&msg);
491   cmsg->cmsg_level = SOL_SOCKET;
492   cmsg->cmsg_type = SCM_RIGHTS;
493   cmsg->cmsg_len = CMSG_LEN (sizeof (int));
494 
495   *((int *) CMSG_DATA (cmsg)) = fd;
496 
497   ret = TEMP_FAILURE_RETRY (sendmsg (server, &msg, 0));
498   if (UNLIKELY (ret < 0))
499     return crun_make_error (err, errno, "sendmsg");
500   return 0;
501 }
