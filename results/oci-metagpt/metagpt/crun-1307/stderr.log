2704|/* If one of stdin, stdout, stderr are pointing to /dev/null on
2705| * the outside of the container, this moves it to /dev/null inside
2706| * of the container. This needs to run after pivot/chroot-ing. */
2707|int
2708|libcrun_reopen_dev_null (libcrun_error_t *err)
2709|{
2710|  struct stat dev_null;
2711|  struct stat statbuf;
2712|  cleanup_close int fd;
2713|  int i;
2714|
2715|  /* Open /dev/null inside of the container. */
2716|  fd = open ("/dev/null", O_RDWR);
2717|  if (UNLIKELY (fd == -1))
2718|    return crun_make_error (err, errno, "failed open()ing `/dev/null`");
2719|
2720|  if (UNLIKELY (fstat (fd, &dev_null) == -1))
2721|    return crun_make_error (err, errno, "failed stat()ing `/dev/null`");
2722|
2723|  for (i = 0; i <= 2; i++)
2724|    {
2725|      if (UNLIKELY (fstat (i, &statbuf) == -1))
2726|        return crun_make_error (err, errno, "failed stat()ing fd `%d`", i);
2727|      if (statbuf.st_rdev == dev_null.st_rdev)
2728|        {
2729|          /* This FD is pointing to /dev/null. Point it to /dev/null inside
2730|           * of the container. */
2731|          if (UNLIKELY (dup2 (fd, i) == -1))
2732|            return crun_make_error (err, errno, "failed dup2()ing `%d`", i);
2733|        }
2734|    }
2735|  return 0;
