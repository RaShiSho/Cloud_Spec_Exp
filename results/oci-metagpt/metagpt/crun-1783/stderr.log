019| *
020| * 2005/09/12: Dan Howell (modified from realpath.c to emulate chroot)
021| * 2019/04/19: Giuseppe Scrivano (on ENOENT return the part that could be resolved)
022| * 2019/09/30: Giuseppe Scrivano (follow symlinks for the last component)
023| * 2020/02/02: Giuseppe Scrivano (don't lose terminal '/' if an absolute symlink is found)
024| */
025|
026|#ifdef HAVE_CONFIG_H
027|#include <config.h>
028|#endif
029|
030|#include <sys/types.h>
031|#include <unistd.h>
032|#include <stdio.h>
033|#include <string.h>
034|#include <strings.h>
035|#include <limits.h>				/* for PATH_MAX */
036|#include <sys/param.h>			/* for MAXPATHLEN */
037|#include <errno.h>
038|#ifndef __set_errno
039|#define __set_errno(val) ((errno) = (val))
040|#endif
041|
042|#include <sys/stat.h>			/* for S_IFLNK */
043|
044|#ifndef PATH_MAX
045|#define PATH_MAX _POSIX_PATH_MAX
046|#endif
047|
048|#define MAX_READLINKS 32
049|
050|char *chroot_realpath(const char *chroot, const char *path, char resolved_path[])
051|{
052|	char copy_path[PATH_MAX];
053|	char link_path[PATH_MAX];
054|	char got_path[PATH_MAX];
055|	char *got_path_root = got_path;
056|	char *new_path = got_path;
057|	char *max_path;
058|	int readlinks = 0;
059|	int n;
060|	int chroot_len;
061|	int last_component;
062|
063|	/* Trivial case. */
064|	if (chroot == NULL || *chroot == '\0' ||
065|	    (*chroot == '/' && chroot[1] == '\0')) {
066|		strcpy(resolved_path, path);
067|		return resolved_path;
068|	}
069|
070|	chroot_len = strlen(chroot);
071|
072|	if (chroot_len + strlen(path) >= PATH_MAX - 3) {
073|		__set_errno(ENAMETOOLONG);
074|		return NULL;
075|	}
076|
077|	/* Make a copy of the source path since we may need to modify it. */
078|	strcpy(copy_path, path);
079|	path = copy_path;
080|	max_path = copy_path + PATH_MAX - chroot_len - 3;
081|
082|	/* Start with the chroot path. */
083|	strcpy(new_path, chroot);
084|	new_path += chroot_len;
085|	while (*new_path == '/' && new_path > got_path)
086|		new_path--;
087|	got_path_root = new_path;
088|	*new_path++ = '/';
089|
090|	/* Expand each slash-separated pathname component. */
091|	while (*path != '\0') {
092|		/* Ignore stray "/". */
093|		if (*path == '/') {
094|			path++;
095|			continue;
096|		}
097|		if (*path == '.') {
098|			/* Ignore ".". */
099|			if (path[1] == '\0' || path[1] == '/') {
100|				path++;
101|				continue;
102|			}
103|			if (path[1] == '.') {
104|				if (path[2] == '\0' || path[2] == '/') {
105|					path += 2;
106|					/* Ignore ".." at root. */
107|					if (new_path == got_path_root + 1)
108|						continue;
109|					/* Handle ".." by backing up. */
110|					while ((--new_path)[-1] != '/');
111|					continue;
112|				}
113|			}
114|		}
115|		/* Safely copy the next pathname component. */
116|		while (*path != '\0' && *path != '/') {
117|			if (path > max_path) {
118|				__set_errno(ENAMETOOLONG);
119|				return NULL;
120|			}
121|			*new_path++ = *path++;
122|		}
123|
124|		last_component = (*path == '\0');
125|
126|#ifdef S_IFLNK
127|		/* Protect against infinite loops. */
128|		if (readlinks++ > MAX_READLINKS) {
129|			__set_errno(ELOOP);
130|			return NULL;
131|		}
132|		/* See if latest pathname component is a symlink. */
133|		*new_path = '\0';
134|		n = readlink(got_path, link_path, PATH_MAX - 1);
135|		if (n < 0) {
136|			/* EINVAL means the file exists but isn't a symlink. */
137|			if (errno != EINVAL)
138|				return NULL;
139|		} else {
140|			/* Note: readlink doesn't add the null byte. */
141|			link_path[n] = '\0';
142|			if (*link_path == '/') {
143|				/* Start over for an absolute symlink. */
144|				new_path = got_path_root;
145|				*new_path++ = '/';
146|			}
147|			else
148|				/* Otherwise back up over this component. */
149|				while (*(--new_path) != '/');
150|			/* Safe sex check. */
151|			if (strlen(path) + n >= PATH_MAX - 2) {
152|				__set_errno(ENAMETOOLONG);
153|				return NULL;
154|			}
155|			/* Insert symlink contents into path. */
156|			strcat(link_path, path);
157|			strcpy(copy_path, link_path);
158|			path = copy_path;
159|		}
160|#endif							/* S_IFLNK */
161|		if (!last_component)
162|			*new_path++ = '/';
163|	}
164|	/* Delete trailing slash but don't whomp a lone slash. */
165|	if (new_path != got_path + 1 && new_path[-1] == '/')
166|		new_path--;
167|	/* Make sure it's null terminated. */
168|	*new_path = '\0';
169|	strcpy(resolved_path, got_path);
170|	return resolved_path;
171|}
