001|use oci_spec::runtime::{LinuxDeviceCgroup, LinuxDeviceType};
002|
003|// For cgroup v1 compatibility, runc implements a device emulator to calculate the final rules given
004|// a list of user-defined rules.
005|// https://github.com/opencontainers/runc/commit/2353ffec2bb670a200009dc7a54a56b93145f141
006|//
007|// I chose to implement a very simple algorithm, which will just work in most cases, but with
008|// diversion from cgroupv1 in some cases:
009|//  1. just add used-defined rules one by one
010|//  2. discard existing rules when encountering a rule with type='a', and change to deny/allow all
011|//     list according the 'allow' of the rule
012|//  3. bpf program will check rule one by one in *reversed* order, return action of first rule
013|//     which matches device access operation
014|//
015|
016|// FIXME: should we use runc's implementation?
017|pub struct Emulator {
018|    pub default_allow: bool,
019|    pub rules: Vec<LinuxDeviceCgroup>,
020|}
021|
022|impl Emulator {
023|    pub fn with_default_allow(default_allow: bool) -> Self {
024|        Emulator {
025|            default_allow,
026|            rules: Vec::new(),
027|        }
028|    }
029|
030|    pub fn add_rules(&mut self, rules: &[LinuxDeviceCgroup]) {
031|        for rule in rules {
032|            self.add_rule(rule);
033|        }
034|    }
035|
036|    pub fn add_rule(&mut self, rule: &LinuxDeviceCgroup) {
037|        // special case, switch to blacklist or whitelist and clear all existing rules
038|        // NOTE: we ignore other fields when type='a', this is same as cgroup v1 and runc
039|        if rule.typ().unwrap_or_default() == LinuxDeviceType::A {
040|            self.default_allow = rule.allow();
041|            self.rules.clear();
042|            return;
043|        }
044|
045|        // empty access match nothing, just discard this rule
046|        if rule.access().is_none() {
047|            return;
048|        }
049|
