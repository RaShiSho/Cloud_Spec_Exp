016|func isPidsSet(r *configs.Resources) bool {
017|	return r.PidsLimit != 0
018|}
019|
020|func setPids(dirPath string, r *configs.Resources) error {
021|	if !isPidsSet(r) {
022|		return nil
023|	}
024|	if val := numToStr(r.PidsLimit); val != "" {
025|		if err := cgroups.WriteFile(dirPath, "pids.max", val); err != nil {
026|			return err
027|		}
028|	}
029|
030|	return nil
031|}
032|
033|func statPidsFromCgroupProcs(dirPath string, stats *cgroups.Stats) error {
034|	// if the controller is not enabled, let's read PIDS from cgroups.procs
035|	// (or threads if cgroup.threads is enabled)
036|	contents, err := cgroups.ReadFile(dirPath, "cgroup.procs")
037|	if errors.Is(err, unix.ENOTSUP) {
038|		contents, err = cgroups.ReadFile(dirPath, "cgroup.threads")
039|	}
040|	if err != nil {
041|		return err
042|	}
043|	pids := strings.Count(contents, "\n")
044|	stats.PidsStats.Current = uint64(pids)
045|	stats.PidsStats.Limit = 0
046|	return nil
047|}
048|
049|func statPids(dirPath string, stats *cgroups.Stats) error {
050|	current, err := fscommon.GetCgroupParamUint(dirPath, "pids.current")
051|	if err != nil {
052|		if os.IsNotExist(err) {
053|			return statPidsFromCgroupProcs(dirPath, stats)
054|		}
055|		return err
056|	}
057|
058|	max, err := fscommon.GetCgroupParamUint(dirPath, "pids.max")
059|	if err != nil {
060|		return err
061|	}
062|	// If no limit is set, read from pids.max returns "max", which is
063|	// converted to MaxUint64 by GetCgroupParamUint. Historically, we
064|	// represent "no limit" for pids as 0, thus this conversion.
065|	if max == math.MaxUint64 {
066|		max = 0
067|	}
068|
069|	stats.PidsStats.Current = current
070|	stats.PidsStats.Limit = max
071|	return nil
072|}
