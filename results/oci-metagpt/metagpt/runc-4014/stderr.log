012|type PidsGroup struct{}
013|
014|func (s *PidsGroup) Name() string {
015|	return "pids"
016|}
017|
018|func (s *PidsGroup) Apply(path string, _ *configs.Resources, pid int) error {
019|	return apply(path, pid)
020|}
021|
022|func (s *PidsGroup) Set(path string, r *configs.Resources) error {
023|	if r.PidsLimit != 0 {
024|		// "max" is the fallback value.
025|		limit := "max"
026|
027|		if r.PidsLimit > 0 {
028|			limit = strconv.FormatInt(r.PidsLimit, 10)
029|		}
030|
031|		if err := cgroups.WriteFile(path, "pids.max", limit); err != nil {
032|			return err
033|		}
034|	}
035|
036|	return nil
037|}
038|
039|func (s *PidsGroup) GetStats(path string, stats *cgroups.Stats) error {
040|	if !cgroups.PathExists(path) {
041|		return nil
042|	}
043|	current, err := fscommon.GetCgroupParamUint(path, "pids.current")
044|	if err != nil {
045|		return err
046|	}
047|
048|	max, err := fscommon.GetCgroupParamUint(path, "pids.max")
049|	if err != nil {
050|		return err
051|	}
052|	// If no limit is set, read from pids.max returns "max", which is
053|	// converted to MaxUint64 by GetCgroupParamUint. Historically, we
054|	// represent "no limit" for pids as 0, thus this conversion.
055|	if max == math.MaxUint64 {
056|		max = 0
057|	}
058|
059|	stats.PidsStats.Current = current
060|	stats.PidsStats.Limit = max
061|	return nil
