018|// numToStr converts an int64 value to a string for writing to a
019|// cgroupv2 files with .min, .max, .low, or .high suffix.
020|// The value of -1 is converted to "max" for cgroupv1 compatibility
021|// (which used to write -1 to remove the limit).
022|func numToStr(value int64) (ret string) {
023|	switch {
