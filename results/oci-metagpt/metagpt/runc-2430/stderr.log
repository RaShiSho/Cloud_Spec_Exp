|\t\t\t\t}\n529|\t\t\t\tif r.CPU.Quota != nil {\n530|\t\t\t\t\tc.Resources.CpuQuota = *r.CPU.Quota\n531|\t\t\t\t}\n532|\t\t\t\tif r.CPU.Period != nil {\n533|\t\t\t\t\tc.Resources.CpuPeriod = *r.CPU.Period\n534|\t\t\t\t}\n535|\t\t\t\t//CpuMax is used for cgroupv2 and should be converted\n536|\t\t\t\tc.Resources.CpuMax = cgroups.ConvertCPUQuotaCPUPeriodToCgroupV2Value(c.Resources.CpuQuota, c.Resources.CpuPeriod)\n537|\n538|\t\t\t\tif r.CPU.RealtimeRuntime != nil {\n539|\t\t\t\t\tc.Resources.CpuRtRuntime = *r.CPU.RealtimeRuntime\n540|\t\t\t\t}\n541|\t\t\t\tif r.CPU.RealtimePeriod != nil {\n542|\t\t\t\t\tc.Resources.CpuRtPeriod = *r.CPU.RealtimePeriod\n543|\t\t\t\t}\n544|\t\t\t\tif r.CPU.Cpus != "" {\n545|\t\t\t\t\tc.Resources.CpusetCpus = r.CPU.Cpus\n546|\t\t\t\t}\n547|\t\t\t\tif r.CPU.Mems != "" {\n548|\t\t\t\t\tc.Resources.CpusetMems = r.CPU.Mems\n549|\t\t\t\t}\n550|\t\t\t}\n551|\t\t\tif r.Pids != nil {\n552|\t\t\t\tc.Resources.PidsLimit = r.Pids.Limit\n553|\t\t\t}\n554|\t\t\tif r.BlockIO != nil {\n555|\t\t\t\tif r.BlockIO.Weight != nil {\n556|\t\t\t\t\tc.Resources.BlkioWeight = *r.BlockIO.Weight\n557|\t\t\t\t}\n558|\t\t\t\tif r.BlockIO.LeafWeight != nil {\n559|\t\t\t\t\tc.Resources.BlkioLeafWeight = *r.BlockIO.LeafWeight\n560|\t\t\t\t}\n561|\t\t\t\tif r.BlockIO.WeightDevice != nil {\n562|\t\t\t\t\tfor _, wd := range r.BlockIO.WeightDevice {\n563|\t\t\t\t\t\tvar weight, leafWeight uint16\n564|\t\t\t\t\t\tif wd.Weight != nil {\n565|\t\t\t\t\t\t\tweight = *wd.Weight\n566|\t\t\t\t\t\t}\n567|\t\t\t\t\t\tif wd.LeafWeight != nil {\n568|\t\t\t\t\t\t\tleafWeight = *wd.LeafWeight\n569|\t\t\t\t\t\t}\n570|\t\t\t\t\t\tweightDevice := configs.NewWeightDevice(wd.Major, wd.Minor, weight, leafWeight)\n571|\t\t\t\t\t\tc.Resources.BlkioWeightDevice = append(c.Resources.BlkioWeightDevice, weightDevice)\n572|\t\t\t\t\t}\n573|\t\t\t\t}\n574|\t\t\t\tif r.BlockIO.ThrottleReadBpsDevice != nil {\n575|\t\t\t\t\tfor _, td := range r.BlockIO.ThrottleReadBpsDevice {\n576|\t\t\t\t\t\trate := td.R