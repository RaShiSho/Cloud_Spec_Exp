 is a rule to match a syscall in Seccomp\n072|type Syscall struct {\n073|\tName     string `json:"name"`\n074|\tAction   Action `json:"action"`\n075|\tErrnoRet *uint  `json:"errnoRet"`\n076|\tArgs     []*Arg `json:"args"`\n077|}\n078|\n079|// TODO Windows. Many of these fields should be factored out into those parts\n080|// which are common across platforms, and those which are platform specific.\n081|\n082|// Config defines configuration options for executing a process inside a contained environment.\n083|type Config struct {\n084|\t// NoPivotRoot will use MS_MOVE and a chroot to jail the process into the container\'s rootfs\n085|\t// This is a common option when the container is running in ramdisk\n086|\tNoPivotRoot bool `json:"no_pivot_root"`\n087|\n088|\t// ParentDeathSignal specifies the signal that is sent to the container\'s process in the case\n089|\t// that the parent process dies.\n090|\tParentDeathSignal int `json:"parent_death_signal"`\n091|\n092|\t// Path to a directory containing the container\'s root filesystem.\n093|\tRootfs string `json:"rootfs"`\n094|\n095|\t// Readonlyfs will remount the container\'s rootfs as readonly where only externally mounted\n096|\t// bind mounts are writtable.\n097|\tReadonlyfs bool `json:"readonlyfs"`\n098|\n099|\t// Specifies the mount propagation flags to be applied to /.\n100|\tRootPropagation int `json:"rootPropagation"`\n101|\n102|\t// Mounts specify additional source and destination paths that will be mounted inside the container\'s\n103|\t// rootfs and mount namespace if specified\n104|\tMounts []*Mount `json:"mounts"`\n105|\n106|\t// The device nodes that should be automatically created within the container upon container start.  Note, make sure that the node is marked as allowed in the cgroup as well!\n107|\tDevices []*Device `json:"devices"`\n108|\n109|\tMountLabel string `json:"mount_label"`\n110|\n111|\t// Hostname optionally sets the container\'s hostname if provided\n112|\tHostname string `json:"hostname"`\n113|\n114|\t// Namespaces specifies the container\'s namespaces that it should setup when cloning the init process\n115|\t// If a namespace is not provided that namespace is shared from the container\'s parent process\n116|\tNamespaces Namespaces `json:"namespaces"`\n117|\n118|\t// Capabilities specify the capabilities to keep when executing the process inside the container\n119|\t// All capabilities not specified will be dropped from the processes capability mask\n120|\tCapabilities *Capabilities `json:"capabilities"`\n121|\n122|\t// Networks specifies the container\'s network setup to be created\n123|\tNetworks []*Network `json:"networks"`\n124|\n125|\t// Routes can be specified to create entries in the route table as the container is started\n126|\tRoutes []*Route `json:"routes"`\n127|\n128|\t// Cgroups specifies specific cgroup settings for the various subsystems that the container is\n129|\t// placed into to limit the resources the container has available\n130|\tCgroups *Cgroup `json:"cgroups"`\n131|\n132|\t// AppArmorProfile specifies the profile to apply to the process running in the container and is\n133|\t// change at the time the process is execed\n134|\tAppArmorProfile string `json:"apparmor_profile,omitempty"`\n135|\n136|\t// ProcessLabel specifies the label to apply to the process running in the container.  It is\n137|\t// commonly used by selinux\n138|\tProcessLabel string `json:"process_label,omitempty"`\n139|\n140|\t// Rlimits specifies the resource limits, such as max open files, to set in the container\n141|\t// If Rlimits are not set, the container will inherit rlimits from the parent process\n142|\tRlimits []Rlimit `json:"rlimits,omitempty"`\n143|\n144|\t// OomScoreAdj specifies the adjustment to be made by the kernel when calculating oom scores\n145|\t// for a process. Valid values are between the range [-1000, \'1000\'], where processes with\n146|\t// higher scores are preferred for being killed. If it is unset then we don\'t touch the current\n147|\t// value.\n148|\t// More information about kernel oom score calculation here: https://lwn.net/Articles/317814/\n149|\tOomScoreAdj *int `json:"oom_score_adj,omitempty"`\n150|\n151|\t// UidMappings is an array of User ID mappings for User Namespaces\n152|\tUidMappings []IDMap `json:"uid_mappings"`\n153|\n154|\t// GidMappings is an array of Group ID mappings for User Namespaces\n155|\tGidMappings []IDMap `json:"gid_mappings"`\n156|\n157|\t// MaskPaths specifies paths within the container\'s rootfs to mask over with a bind\n158|\t// mount pointing to /dev/null as to prevent reads of the file.\n159|\tMaskPaths []string `json:"mask_paths"`\n160|\n161|\t// ReadonlyPaths specifies paths within the container\'s rootfs to remount as read-only\n162|\t// so that these files prevent any writes.\n163|\tReadonlyPaths []string `json:"readonly_paths"`\n164|\n165|\t// Sysctl is a map of properties and their values. It is the equivalent of using\n166|\t// sysctl -w my.property.name value in Linux.\n167|\tSysctl map[string]string `json:"sysctl"`\n168|\n169|\t// Seccomp allows actions to be taken whenever a syscall is made within the container.\n170|\t// A number of rules are given, each having an action to be taken if a syscall matches it.\n171|\t// A default action to be taken if no rules match is also given.\n172|\tSeccomp *Seccomp `json:"seccomp"`\n173|\n174|\t// NoNewPrivileges controls whether processes in the container can gain additional privileges.\n175|\tNoNewPrivileges bool `json:"no_new_privileges,omitempty"`\n176|\n177|\t// Hooks are a collection of actions to perform at various container lifecycle events.\n178|\t// CommandHooks are serialized to JSON, but other hooks are not.\n179|\tHooks *Hooks\n180|\n181|\t// Version is the version of opencontainer specification that is supported.\n182|\tVersion string `json:"version"`\n183|\n184|\t// Labels are user defined metadata that is stored in the config and populated on the state\n185|\tLabels []string `json:"labels"`\n18