rr)\n056|\t\t}\n057|\n058|\t\tif err := filter.AddArch(scmpArch); err != nil {\n059|\t\t\treturn fmt.Errorf("error adding architecture to seccomp filter: %s", err)\n060|\t\t}\n061|\t}\n062|\n063|\t// Unset no new privs bit\n064|\tif err := filter.SetNoNewPrivsBit(false); err != nil {\n065|\t\treturn fmt.Errorf("error setting no new privileges: %s", err)\n066|\t}\n067|\n068|\t// Add a rule for each syscall\n069|\tfor _, call := range config.Syscalls {\n070|\t\tif call == nil {\n071|\t\t\treturn errors.New("encountered nil syscall while initializing Seccomp")\n072|\t\t}\n073|\n074|\t\tif err = matchCall(filter, call); err != nil {\n075|\t\t\treturn err\n076|\t\t}\n077|\t}\n078|\n079|\tif err = filter.Load(); err != nil {\n080|\t\treturn fmt.Errorf("error loading seccomp filter into kernel: %s", err)\n081|\t}\n082|\n083|\treturn nil\n084|}\n085|\n086|// IsEnabled returns if the kernel has been configured to support seccomp.\n087|func IsEnabled() bool {\n088|\t// Try to read from /proc/self/status for kernels > 3.8\n089|\ts, err := parseStatusFile("/proc/self/status")\n090|\tif err != nil {\n091|\t\t// Check if Seccomp is supported, via CONFIG_SECCOMP.\n092|\t\tif err := unix.Prctl(unix.PR_GET_SECCOMP, 0, 0, 0, 0); err != unix.EINVAL {\n093|\t\t\t// Make sure the kernel has CONFIG_SECCOMP_FILTER.\n094|\t\t\tif err := unix.Prctl(unix.PR_SET_SECCOMP, unix.SECCOMP_MODE_FILTER, 0, 0, 0); err != unix.EINVAL {\n095|\t\t\t\treturn true\n096|\t\t\t}\n097|\t\t}\n098|\t\treturn false\n099|\t}\n100|\t_, ok := s["Seccomp"]\n101|\treturn ok\n102|}\n103|\n104|// Convert Libcontainer Action to Libseccomp ScmpAction\n105|func getAction(act configs.Action, errnoRet *uint) (libseccomp.ScmpAction, error) {\n106|\tswitch act {\n107|\tcase configs.Kill:\n108|\t\treturn actKill, nil\n109|\tcase configs.Errno:\n110|\t\tif errnoRet != nil {\n111|\t\t\treturn libseccomp.ActErrno.SetReturnCode(int16(*errnoRet)), nil\n112|\t\t}\n113|\t\treturn actErrno, nil\n114|\tcase configs.Trap:\n115|\t\treturn actTrap, nil\n116|\tcase configs.Allow:\n117|\t\treturn actAllow, nil\n118|\tcase configs.Trace:\n119|\t\tif errnoRet != nil {\n120|\t\t\treturn libseccomp.ActTrace.SetReturnCode(int16(*errnoRet)), nil\n121|\t\t}\n122|\t\treturn actTrace, nil\n123|\tcase configs.Log:\n124|\t\treturn actLog, nil\n125|\tdefault:\n126|\t\treturn libseccomp.ActInvalid, errors.New("invalid action, cannot use in rule")\n127|\t}\n128|}\n129|\n130|// Convert Libcontainer Operator to Libseccomp ScmpCompareOp\n131|func getOperator(op configs.Operator) (libseccomp.ScmpCompareOp, error) {\n132|\tswitch op {\n133|\tcase configs.EqualTo:\n134|\t\treturn libseccomp.CompareEqual, nil\n135|\tcase configs.NotEqualTo:\n136|\t\treturn libseccomp.CompareNotEqual, nil\n137|\tcase configs.GreaterThan:\n138|\t\treturn libseccomp.CompareGreater, nil\n139|\tcase configs.GreaterThanOrEqualTo:\n140|\t\treturn libseccomp.CompareGreaterEqual, nil\n141|\tcase configs.LessThan:\n142|\t\treturn libseccomp.CompareLess, nil\n143|\tcase configs.LessThanOrEqualTo:\n144|\t\treturn libseccomp.CompareLessOrEqual, nil\n145|\tcase configs.MaskEqualTo:\n146|\t\treturn libseccomp.CompareMaskedEqual, nil\n147|\tdefault:\n148|\t\treturn libseccomp.CompareInvalid, errors.New("invalid operator, cannot use in rule")\n149|\t}\n150|}\n151|\n152|// Convert Libcontainer Arg to Libseccomp ScmpCondition\n153|func getCondition(arg *configs.Arg) (libseccomp.ScmpCondition, error) {\n154|\tcond := libseccomp.ScmpCondition{}\n155|\n156|\tif arg == nil {\n157|\t\treturn cond, errors.New("cannot convert nil to syscall condition")\n158|\t}\n159|\n160|\top, err := getOperator(arg.Op)\n161|\tif err != nil {\n162|\t\treturn cond, err\n163|\t}\n164|\n165|\treturn libseccomp.MakeCondition(arg.Index, op, arg.Value, arg.ValueTwo)\n166|}\n167|\n168|// Add a rule to match a single syscall\n169|func matchCall(filter *libseccomp.ScmpFilter, call *configs.Syscall) error {\n170|\tif call == nil || filter == nil {\n171|\t\treturn errors.New("cannot use nil as syscall to block")\n172|\t}\n173|\n174|\tif len(call.Name) == 0 {\n175|\t\treturn errors.New("empty string is not a valid syscall")\n176|\t}\n177|\n178|\t// If we can\'t resolve the syscall, assume it\'s not supported on this kernel\n179|\t// Ignore it, don\'t error out\n180|\tcallNum, err := libseccomp.GetSyscallFromName(call.Name)\n181|\tif err != nil {\n182|\t\treturn nil\n183|\t}\n184|\n185|\t// Convert the call\'s action to the libseccomp equivalent\n186|\tcallAct, err := getAction(call.Action, call.ErrnoRet)\n187|\tif err != nil {\n188|\t\treturn fmt.Errorf("action in seccomp profile is invalid: %s", err)\n189|\t}\n190|\n191|\t// Unconditional match - just add the rule\n192|\tif len(call.Args) == 0 {\n193|\t\tif err = filter.AddRule(callNum, callAct); err != nil {\n194|\t\t\treturn fmt.Errorf("error adding seccomp filter rule for syscall %s: %s", call.Name, err)\n195|\t\t}\n196|\t} else {\n197|\t\t// If two or more arguments have the same condition,\n198|\t\t// Revert to old behavior, adding each condition as a separate rule\n199|\t\targCounts := make([]uint, syscallMaxArguments)\n200|\t\tconditions := []libseccomp.ScmpCondition{}\n201|\n202|\t\tfor _, cond := range call.Args {\n203|\t\t\tnewCond, err := getCondition(cond)\n204|\t\t\tif err != nil {\n205|\t\t\t\treturn fmt.Errorf("error creating seccomp syscall condition for syscall %s: %s", call.Name, err)\n206|\t\t\t}\n207|\n208|\t\t\targCounts[cond.Index] += 1\n209|\n210|\t\t\tconditions = append(conditions, newCond)\n211|\t\t}\n212|\n213|\t\thasMultipleArgs := false\n214|\t\tfor _, count := range argCounts {\n215|\t\t\tif count > 1 {\n216|\t\t\t\thasMultipleArgs = true\n217|\t\t\t\tbreak\n218|\t\t\t}\n219|\t\t}\n220|\n221|\t\tif hasMultipleArgs {\n222|\t\t\t// Revert to old behavior\n223|\t\t\t// Add each condition attached to a separate rule\n224|\t\t\tfor _, cond := range conditions {\n225|\t\t\t\tcondArr := []libseccomp.ScmpCondition{cond}\n226|\n227|\t\t\t\tif err = filter.AddRuleConditional(callNum, callAct, condArr); err != nil {\n228|\t\t\t\t\treturn fmt.Errorf("error adding seccomp rule for syscall %s: %s", call.Name, err)\n229|\t\t\t\t}\n230|\t\t\t}\n231|\t\t} else {\n232|\t\t\t// No conditions share same argument\n233|\t\t\t// Use new, proper behavior\n234|\t\t\tif err = filter.AddRuleConditional(callNum, callAct, conditions); err != nil {\n235|\t\t\t\treturn fmt.Errorf("error adding seccomp rule for syscall %s: %s", call.Name, err)\n236|\t\t\t}\n237|\t\t}\n238|\t}\n239|\n240|\treturn nil\n241|}\n242|\n243|func parseStatusFile(path string) (map[string]string, error) {\n244|\tf, err := os.Open(path)\n245|\tif err != nil {\n246|\t\treturn nil, err\n247|\t}\n248|\tdefer f.Close()\n249|\n250|\ts := bufio.NewScanner(f)\n251|\tstatus := make(map[string]string)\n252|\n253|\tfor s.Scan() {\n254|\t\ttext := s.Text()\n255|\t\tparts := strings.Split(text, ":")\n256|\n257|\t\tif len(parts) <= 1 {\n258|\t\t\tcontinue\n259|\t\t}\n260|\n261|\t\tstatus[parts[0]] = parts[1]\n262|\t}\n263|\tif err := s.Err(); err != nil {\n264|\t\treturn nil, err\n265|\t}\n266|\n267|\treturn status, nil\n268|}\n'

