030|// VersionError denotes that the system libseccomp version is incompatible
031|// with this package.
032|type VersionError struct {
033|	message string
034|	minimum string
035|}
036|
037|func (e VersionError) Error() string {
038|	format := "Libseccomp version too low: "
039|	if e.message != "" {
040|		format += e.message + ": "
041|	}
042|	format += "minimum supported is "
043|	if e.minimum != "" {
044|		format += e.minimum + ": "
045|	} else {
046|		format += "2.2.0: "
047|	}
048|	format += "detected %d.%d.%d"
049|	return fmt.Sprintf(format, verMajor, verMinor, verMicro)
050|}
