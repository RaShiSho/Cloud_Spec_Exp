unix.MS_BIND},\n747|\t\t"defaults":      {false, 0},\n748|\t\t"dev":           {true, unix.MS_NODEV},\n749|\t\t"diratime":      {true, unix.MS_NODIRATIME},\n750|\t\t"dirsync":       {false, unix.MS_DIRSYNC},\n751|\t\t"exec":          {true, unix.MS_NOEXEC},\n752|\t\t"iversion":      {false, unix.MS_I_VERSION},\n753|\t\t"lazytime":      {false, unix.MS_LAZYTIME},\n754|\t\t"loud":          {true, unix.MS_SILENT},\n755|\t\t"mand":          {false, unix.MS_MANDLOCK},\n756|\t\t"noacl":         {true, unix.MS_POSIXACL},\n757|\t\t"noatime":       {false, unix.MS_NOATIME},\n758|\t\t"nodev":         {false, unix.MS_NODEV},\n759|\t\t"nodiratime":    {false, unix.MS_NODIRATIME},\n760|\t\t"noexec":        {false, unix.MS_NOEXEC},\n761|\t\t"noiversion":    {true, unix.MS_I_VERSION},\n762|\t\t"nolazytime":    {true, unix.MS_LAZYTIME},\n763|\t\t"nomand":        {true, unix.MS_MANDLOCK},\n764|\t\t"norelatime":    {true, unix.MS_RELATIME},\n765|\t\t"nostrictatime": {true, unix.MS_STRICTATIME},\n766|\t\t"nosuid":        {false, unix.MS_NOSUID},\n767|\t\t"rbind":         {false, unix.MS_BIND | unix.MS_REC},\n768|\t\t"relatime":      {false, unix.MS_RELATIME},\n769|\t\t"remount":       {false, unix.MS_REMOUNT},\n770|\t\t"ro":            {false, unix.MS_RDONLY},\n771|\t\t"rw":            {true, unix.MS_RDONLY},\n772|\t\t"silent":        {false, unix.MS_SILENT},\n773|\t\t"strictatime":   {false, unix.MS_STRICTATIME},\n774|\t\t"suid":          {true, unix.MS_NOSUID},\n775|\t\t"sync":          {false, unix.MS_SYNCHRONOUS},\n776|\t}\n777|\tpropagationFlags := map[string]int{\n778|\t\t"private":     unix.MS_PRIVATE,\n779|\t\t"shared":      unix.MS_SHARED,\n780|\t\t"slave":       unix.MS_SLAVE,\n781|\t\t"unbindable":  unix.MS_UNBINDABLE,\n782|\t\t"rprivate":    unix.MS_PRIVATE | unix.MS_REC,\n783|\t\t"rshared":     unix.MS_SHARED | unix.MS_REC,\n784|\t\t"rslave":      unix.MS_SLAVE | unix.MS_REC,\n785|\t\t"runbindable": unix.MS_UNBINDABLE | unix.MS_REC,\n786|\t}\n787|\textensionFlags := map[s