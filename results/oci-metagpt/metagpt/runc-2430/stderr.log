ome systemd properties are documented as having "Sec" suffix\n355|// (e.g. TimeoutStopSec) but are expected to have "USec" suffix\n356|// here, so let\'s provide conversion to improve compatibility.\n357|func convertSecToUSec(value dbus.Variant) (dbus.Variant, error) {\n358|\tvar sec uint64\n359|\tconst M = 1000000\n360|\tvi := value.Value()\n361|\tswitch value.Signature().String() {\n362|\tcase "y":\n363|\t\tsec = uint64(vi.(byte)) * M\n364|\tcase "n":\n365|\t\tsec = uint64(vi.(int16)) * M\n366|\tcase "q":\n367|\t\tsec = uint64(vi.(uint16)) * M\n368|\tcase "i":\n369|\t\tsec = uint64(vi.(int32)) * M\n370|\tcase "u":\n371|\t\tsec = uint64(vi.(uint32)) * M\n372|\tcase "x":\n373|\t\tsec = uint64(vi.(int64)) * M\n374|\tcase "t":\n375|\t\tsec = vi.(uint64) * M\n376|\tcase "d":\n377|\t\tsec = uint64(vi.(float64) * M)\n378|\tdefault:\n379|\t\treturn value, errors.New("not a number")\n380|\t}\n381|\treturn dbus.MakeVariant(sec), nil\n382|}\n383|\n384|func initSystemdProps(spec *specs.Spec) ([]systemdDbus.Property, error) {\n385|\tconst keyPrefix = "org.systemd.property."\n386|\tvar sp []systemdDbus.Property\n387|\n388|\tfor k, v := range spec.Annotations {\n389|\t\tname := strings.TrimPrefix(k, keyPrefix)\n390|\t\tif len(name) == len(k) { // prefix not there\n391|\t\t\tcontinue\n392|\t\t}\n393|\t\tif !isValidName(name) {\n394|\t\t\treturn nil, fmt.Errorf("Annotation %s name incorrect: %s", k, name)\n395|\t\t}\n396|\t\tvalue, err := dbus.ParseVariant(v, dbus.Signature{})\n397|\t\tif err != nil {\n398|\t\t\treturn nil, fmt.Errorf("Annotation %s=%s value parse error: %v", k, v, err)\n399|\t\t}\n400|\t\tif isSecSuffix(name) {\n401|\t\t\tname = strings.TrimSuffix(name, "Sec") + "USec"\n402|\t\t\tvalue, err = convertSecToUSec(value)\n403|\t\t\tif err != nil {\n404|\t\t\t\treturn nil, fmt.Errorf("Annotation %s=%s value parse error: %v", k, v, err)\n405|\t\t\t}\n406|\t\t}\n407|\t\tsp = append(sp, systemdDbus.Property{Name: name, Value: value})\n408|\t}\n409|\n410|\treturn sp, nil\n411|}\n412|\n413|func CreateCgroupConfig(opts *CreateOpts) (*configs.Cgroup, error) {\n414|\tvar (\n415|\t\tmyCgroupPath string\n416|\n417|\t\tspec             = opts.Spec\n418|\t\tuseSystemdCgroup = opts.UseSystemdCgroup\n419|\t\tname             = opts.CgroupName\n420|\t)\n421|\n422|\tc := &configs.Cgroup{\n423|\t\tResources: &configs.Resources{},\n424|\t}\n425|\n426|\tif useSystemdCgroup {\n427|\t\tsp, err := initSystemdProps(spec)\n428|\t\tif err != nil {\n429|\t\t\treturn nil, err\n430|\t\t}\n431|\t\tc.SystemdProps = sp\n432|\t}\n433|\n434|\tif spec.Linux != nil && spec.Linux.CgroupsPath != "" {\n435|\t\tmyCgroupPath = libcontainerUtils.CleanPath(spec.Linux.CgroupsPath)\n436|\t\tif useSystemdCgroup {\n437|\t\t\tmyCgroupPath = spec.Linux.CgroupsPath\n438|\t\t}\n439|\t}\n440|\n441|\tif useSystemdCgroup {\n442|\t\tif myCgroupPath == "" {\n443|\t\t\tc.Parent = "system.slice"\n444|\t\t\tc.ScopePrefix = "runc"\n445|\t\t\tc.Name = name\n446|\t\t} else {\n447|\t\t\t// Parse the path from expected "slice:prefix:name"\n448|\t\t\t// for e.g. "system.slice:docker:1234"\n449|\t\t\tparts := strings.Split(myCgroupPath, ":")\n450|\t\t\tif len(parts) != 3 {\n451|\t\t\t\treturn nil, fmt.Errorf("expected cgroupsPath to be of format \\"slice:prefix:name\\" for systemd cgroups, got %q instead", myCgroupPath)\n452|\t\t\t}\n453|\t\t\tc.Parent = parts[0]\n454|\t\t\tc.ScopePrefix = parts[1]\n455|\t\t\tc.Name = parts[2]\n456|\t\t}\n457|\t} else {\n458|\t\tif myCgroupPath == "" {\n459|\t\t\tc.Name = name\n460|\t\t}\n461|\t\tc.Path = myCgroupPath\n462|\t}\n463|\n464|\t// In rootless containers, any attempt to make cgroup changes is likely to fail.\n465|\t// libcontainer will validate this but ignores the error.\n466|\tif spec.Linux != nil {\n467|\t\tr := spec.Linux.Resources\n468|\t\tif r != nil {\n469|\t\t\tfor i, d := range spec.Linux.Resources.Devices {\n470|\t\t\t\tvar (\n471|\t\t\t\t\tt     = "a"\n472|\t\t\t\t\tmajor = int64(-1)\n473|\t\t\t\t\tminor = int64(-1)\n474|\t\t\t\t)\n475|\t