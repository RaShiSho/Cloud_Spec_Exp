fig.DefaultAction = newDefaultAction\n848|\n849|\t// Loop through all syscall blocks and convert them to libcontainer format\n850|\tfor _, call := range config.Syscalls {\n851|\t\tnewAction, err := seccomp.ConvertStringToAction(string(call.Action))\n852|\t\tif err != nil {\n853|\t\t\treturn nil, err\n854|\t\t}\n855|\n856|\t\tfor _, name := range call.Names {\n857|\t\t\tnewCall := configs.Syscall{\n858|\t\t\t\tName:     name,\n859|\t\t\t\tAction:   newAction,\n860|\t\t\t\tErrnoRet: call.ErrnoRet,\n861|\t\t\t\tArgs:     []*configs.Arg{},\n862|\t\t\t}\n863|\t\t\t// Loop through all the arguments of the syscall and convert them\n864|\t\t\tfor _, arg := range call.Args {\n865|\t\t\t\tnewOp, err := seccomp.ConvertStringToOperator(string(arg.Op))\n866|\t\t\t\tif err != nil {\n867|\t\t\t\t\treturn nil, err\n868|\t\t\t\t}\n869|\n870|\t\t\t\tnewArg := configs.Arg{\n871|\t\t\t\t\tIndex:    arg.Index,\n872|\t\t\t\t\tValue:    arg.Value,\n873|\t\t\t\t\tValueTwo: arg.ValueTwo,\n874|\t\t\t\t\tOp:       newOp,\n875|\t\t\t\t}\n876|\n877|\t\t\t\tnewCall.Args = append(newCall.Args, &newArg)\n878|\t\t\t}\n879|\t\t\tnewConfig.Syscalls = append(newConfig.Syscalls, &newCall)\n880|\t\t}\n881|\t}\n882|\n883|\treturn newConfig, nil\n884|}\n885|\n886|func createHooks(rspec *specs.Spec, config *configs.Config) {\n887|\tconfig.Hooks = &configs.Hooks{}\n888|\tif rspec.Hooks != nil {\n889|\n890|\t\tfor _, h := range rspec.Hooks.Prestart {\n891|\t\t\tcmd := createCommandHook(h)\n892|\t\t\tconfig.Hooks.Prestart = append(config.Hooks.Prestart, configs.NewCommandHook(cmd))\n893|\t\t}\n894|\t\tfor _, h := range rspec.Hooks.Poststart {\n895|\t\t\tcmd := createCommandHook(h)\n896|\t\t\tconfig.Hooks.Poststart = append(config.Hooks.Poststart, configs.NewCommandHook(cmd))\n897|\t\t}\n898|\t\tfor _, h := range rspec.Hooks.Poststop {\n899|\t\t\tcmd := createCommandHook(h)\n900|\t\t\tconfig.Hooks.Poststop = append(config.Hooks.Poststop, configs.NewCommandHook(cmd))\n901|\t\t}\n902|\t}\n903|}\n904|\n905|func c