018|type check func(config *configs.Config) error
019|
020|func Validate(config *configs.Config) error {
021|	checks := []check{
022|		cgroupsCheck,
023|		rootfs,
024|		network,
025|		uts,
026|		security,
027|		namespaces,
028|		sysctl,
029|		intelrdtCheck,
030|		rootlessEUIDCheck,
031|		mounts,
032|	}
033|	for _, c := range checks {
034|		if err := c(config); err != nil {
035|			return err
036|		}
037|	}
038|	return nil
039|}
040|
041|// rootfs validates if the rootfs is an absolute path and is not a symlink
042|// to the container's root filesystem.
043|func rootfs(config *configs.Config) error {
044|	if _, err := os.Stat(config.Rootfs); err != nil {
045|		return fmt.Errorf("invalid rootfs: %w", err)
046|	}
047|	cleaned, err := filepath.Abs(config.Rootfs)
048|	if err != nil {
049|		return fmt.Errorf("invalid rootfs: %w", err)
050|	}
051|	if cleaned, err = filepath.EvalSymlinks(cleaned); err != nil {
052|		return fmt.Errorf("invalid rootfs: %w", err)
053|	}
054|	if filepath.Clean(config.Rootfs) != cleaned {
055|		return errors.New("invalid rootfs: not an absolute path, or a symlink")
056|	}
057|	return nil
058|}
059|
060|func network(config *configs.Config) error {
061|	if !config.Namespaces.Contains(configs.NEWNET) {
062|		if len(config.Networks) > 0 || len(config.Routes) > 0 {
063|			return errors.New("unable to apply network settings without a private NET namespace")
064|		}
065|	}
066|	return nil
067|}
068|
069|func uts(config *configs.Config) error {
070|	if config.Hostname != "" && !config.Namespaces.Contains(configs.NEWUTS) {
071|		return errors.New("unable to set hostname without a private UTS namespace")
072|	}
073|	if config.Domainname != "" && !config.Namespaces.Contains(configs.NEWUTS) {
074|		return errors.New("unable to set domainname without a private UTS namespace")
075|	}
076|	return nil
077|}
078|
079|func security(config *configs.Config) error {
080|	// restrict sys without mount namespace
081|	if (len(config.MaskPaths) > 0 || len(config.ReadonlyPaths) > 0) &&
082|		!config.Namespaces.Contains(configs.NEWNS) {
083|		return errors.New("unable to restrict sys entries without a private MNT namespace")
084|	}
085|	if config.ProcessLabel != "" && !selinux.GetEnabled() {
086|		return errors.New("selinux label is specified in config, but selinux is disabled or not supported")
087|	}
088|
089|	return nil
090|}
