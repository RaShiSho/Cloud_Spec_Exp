092|func namespaces(config *configs.Config) error {
093|	if config.Namespaces.Contains(configs.NEWUSER) {
094|		if _, err := os.Stat("/proc/self/ns/user"); os.IsNotExist(err) {
095|			return errors.New("USER namespaces aren't enabled in the kernel")
096|		}
097|	} else {
098|		if config.UIDMappings != nil || config.GIDMappings != nil {
099|			return errors.New("User namespace mappings specified, but USER namespace isn't enabled in the config")
100|		}
101|	}
102|
103|	if config.Namespaces.Contains(configs.NEWCGROUP) {
104|		if _, err := os.Stat("/proc/self/ns/cgroup"); os.IsNotExist(err) {
105|			return errors.New("cgroup namespaces aren't enabled in the kernel")
106|		}
107|	}
108|
109|	return nil
