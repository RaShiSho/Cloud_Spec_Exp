112|// convertSysctlVariableToDotsSeparator can return sysctl variables in dots separator format.
113|// The '/' separator is also accepted in place of a '.'.
114|// Convert the sysctl variables to dots separator format for validation.
115|// More info: sysctl(8), sysctl.d(5).
116|//
117|// For example:
118|// Input sysctl variable "net/ipv4/conf/eno2.100.rp_filter"
119|// will return the converted value "net.ipv4.conf.eno2/100.rp_filter"
120|func convertSysctlVariableToDotsSeparator(val string) string {
121|	if val == "" {
122|		return val
123|	}
124|	firstSepIndex := strings.IndexAny(val, "./")
125|	if firstSepIndex == -1 || val[firstSepIndex] == '.' {
126|		return val
127|	}
128|
129|	f := func(r rune) rune {
130|		switch r {
131|		case '.':
132|			return '/'
133|		case '/':
134|			return '.'
135|		}
136|		return r
137|	}
138|	return strings.Map(f, val)
139|}
