115|// More info: sysctl(8), sysctl.d(5).
116|//
117|// For example:
118|// Input sysctl variable "net/ipv4/conf/eno2.100.rp_filter"
119|// will return the converted value "net.ipv4.conf.eno2/100.rp_filter"
120|func convertSysctlVariableToDotsSeparator(val string) string {
121|	if val == "" {
122|		return val
123|	}
124|	firstSepIndex := strings.IndexAny(val, "./")
125|	if firstSepIndex == -1 || val[firstSepIndex] == '.' {
126|		return val
127|	}
128|
129|	f := func(r rune) rune {
130|		switch r {
131|		case '.':
132|			return '/'
133|		case '/':
134|			return '.'
135|		}
136|		return r
137|	}
138|	return strings.Map(f, val)
139|}
140|
141|// sysctl validates that the specified sysctl keys are valid or not.
142|// /proc/sys isn't completely namespaced and depending on which namespaces
143|// are specified, a subset of sysctls are permitted.
144|func sysctl(config *configs.Config) error {
145|	validSysctlMap := map[string]bool{
146|		"kernel.msgmax":          true,
147|		"kernel.msgmnb":          true,
148|		"kernel.msgmni":          true,
149|		"kernel.sem":             true,
150|		"kernel.shmall":          true,
151|		"kernel.shmmax":          true,
152|		"kernel.shmmni":          true,
153|		"kernel.shm_rmid_forced": true,
154|	}
155|
156|	var (
157|		netOnce    sync.Once
158|		hostnet    bool
159|		hostnetErr error
160|	)
161|
162|	for s := range config.Sysctl {
163|		s := convertSysctlVariableToDotsSeparator(s)
164|		if validSysctlMap[s] || strings.HasPrefix(s, "fs.mqueue.") {
165|			if config.Namespaces.Contains(configs.NEWIPC) {
166|				continue
167|			} else {
168|				return fmt.Errorf("sysctl %q is not allowed in the hosts ipc namespace", s)
169|			}
170|		}
171|		if strings.HasPrefix(s, "net.") {
172|			// Is container using host netns?
173|			// Here "host" means "current", not "initial".
174|			netOnce.Do(func() {
175|				if !config.Namespaces.Contains(configs.NEWNET) {
176|					hostnet = true
177|					return
178|				}
179|				path := config.Namespaces.PathOf(configs.NEWNET)
180|				if path == "" {
181|					// own netns, so hostnet = false
182|					return
183|				}
184|				hostnet, hostnetErr = isHostNetNS(path)
185|			})
186|			if hostnetErr != nil {
187|				return fmt.Errorf("invalid netns path: %w", hostnetErr)
188|			}
189|			if hostnet {
190|				return fmt.Errorf("sysctl %q not allowed in host network namespace", s)
191|			}
192|			continue
193|		}
194|		if config.Namespaces.Contains(configs.NEWUTS) {
195|			switch s {
196|			case "kernel.domainname":
197|				// This is namespaced and there's no explicit OCI field for it.
198|				continue
199|			case "kernel.hostname":
200|				// This is namespaced but there's a conflicting (dedicated) OCI field for it.
201|				return fmt.Errorf("sysctl %q is not allowed as it conflicts with the OCI %q field", s, "hostname")
202|			}
203|		}
204|		return fmt.Errorf("sysctl %q is not in a separate kernel namespace", s)
205|	}
206|
207|	return nil
208|}
209|
210|func intelrdtCheck(config *configs.Config) error {
211|	if config.IntelRdt != nil {
212|		if config.IntelRdt.ClosID == "." || config.IntelRdt.ClosID == ".." || strings.Contains(config.IntelRdt.ClosID, "/") {
213|			return fmt.Errorf("invalid intelRdt.ClosID %q", config.IntelRdt.ClosID)
214|		}
215|
216|		if !intelrdt.IsCATEnabled() && config.IntelRdt.L3CacheSchema != "" {
217|			return errors.New("intelRdt.l3CacheSchema is specified in config, but Intel RDT/CAT is not enabled")
218|		}
219|		if !intelrdt.IsMBAEnabled() && config.IntelRdt.MemBwSchema != "" {
220|			return errors.New("intelRdt.memBwSchema is specified in config, but Intel RDT/MBA is not enabled")
221|		}
222|	}
223|
224|	return nil
225|}
226|
227|func cgroupsCheck(config *configs.Config) error {
228|	c := config.Cgroups
229|	if c == nil {
230|		return nil
231|	}
232|
233|	if (c.Name != "" || c.Parent != "") && c.Path != "" {
234|		return fmt.Errorf("cgroup: either Path or Name and Parent should be used, got %+v", c)
235|	}
236|
237|	r := c.Resources
238|	if r == nil {
239|		return nil
240|	}
241|
242|	if !cgroups.IsCgroup2UnifiedMode() && r.Unified != nil {
243|		return cgroups.ErrV1NoUnified
244|	}
245|
246|	if cgroups.IsCgroup2UnifiedMode() {
247|		_, err := cgroups.ConvertMemorySwapToCgroupV2Value(r.MemorySwap, r.Memory)
248|		if err != nil {
249|			return err
250|		}
251|	}
252|
253|	return nil
254|}
255|
256|func checkIDMapMounts(config *configs.Config, m *configs.Mount) error {
257|	if !m.IsIDMapped() {
258|		return nil
259|	}
260|
261|	if !m.IsBind() {
262|		return fmt.Errorf("gidMappings/uidMappings is supported only for mounts with the option 'bind'")
263|	}
264|	if config.RootlessEUID {
265|		return fmt.Errorf("gidMappings/uidMappings is not supported when runc is being launched with EUID != 0, needs CAP_SYS_ADMIN on the runc parent's user namespace")
266|	}
267|	if len(config.UIDMappings) == 0 || len(config.GIDMappings) == 0 {
268|		return fmt.Errorf("not yet supported to use gidMappings/uidMappings in a mount without also using a user namespace")
269|	}
270|	if !sameMapping(config.UIDMappings, m.UIDMappings) {
271|		return fmt.Errorf("not yet supported for the mount uidMappings to be different than user namespace uidMapping")
272|	}
273|	if !sameMapping(config.GIDMappings, m.GIDMappings) {
274|		return fmt.Errorf("not yet supported for the mount gidMappings to be different than user namespace gidMapping")
275|	}
276|	if !filepath.IsAbs(m.Source) {
277|		return fmt.Errorf("mount source not absolute")
278|	}
279|
280|	return nil
281|}
282|
283|func mounts(config *configs.Config) error {
284|	for _, m := range config.Mounts {
285|		// We upgraded this to an error in runc 1.2. We might need to
286|		// revert this change if some users haven't still moved to use
287|		// abs paths, in that please move this check inside
288|		// checkIDMapMounts() as we do want to ensure that for idmap
289|		// mounts anyways.
290|		if !filepath.IsAbs(m.Destination) {
291|			return fmt.Errorf("invalid mount %+v: mount destination not absolute", m)
292|		}
293|		if err := checkIDMapMounts(config, m); err != nil {
294|			return fmt.Errorf("invalid mount %+v: %w", m, err)
295|		}
296|	}
297|
298|	return nil
299|}
