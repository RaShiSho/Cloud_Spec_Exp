450|static int
451|write_devices_resources_v1 (int dirfd, runtime_spec_schema_defs_linux_device_cgroup **devs, size_t devs_len,
452|                            libcrun_error_t *err)
453|{
454|  size_t i, len;
455|  int ret;
456|  char *default_devices[] = {
457|    "c *:* m",
458|    "b *:* m",
459|    "c 1:3 rwm",
460|    "c 1:8 rwm",
461|    "c 1:7 rwm",
462|    "c 5:0 rwm",
463|    "c 1:5 rwm",
464|    "c 1:9 rwm",
465|    "c 5:1 rwm",
466|    "c 136:* rwm",
467|    "c 5:2 rwm",
468|    NULL
469|  };
470|
471|  for (i = 0; i < devs_len; i++)
472|    {
473|      /* It is plenty of room for "TYPE MAJOR:MINOR ACCESS", where type is one char, and ACCESS is at most 3.   */
474|#define FMT_BUF_LEN 64
475|      char fmt_buf[FMT_BUF_LEN];
476|      const char *file = devs[i]->allow ? "devices.allow" : "devices.deny";
477|
478|      if (devs[i]->type == NULL || devs[i]->type[0] == 'a')
479|        {
480|          strcpy (fmt_buf, "a");
481|          len = 1;
482|        }
483|      else
484|        {
485|          char fmt_buf_major[16];
486|          char fmt_buf_minor[16];
487|
488|#define FMT_DEV(x, b)               \
489|  do                                \
490|    {                               \
491|      if (x##_present)              \
492|        sprintf (b, "%" PRIi64, x); \
493|      else                          \
494|        strcpy (b, "*");            \
495|  } while (0)
496|
497|          FMT_DEV (devs[i]->major, fmt_buf_major);
498|          FMT_DEV (devs[i]->minor, fmt_buf_minor);
499|
500|          len = snprintf (fmt_buf, FMT_BUF_LEN - 1, "%s %s:%s %s", devs[i]->type, fmt_buf_major, fmt_buf_minor,
501|                          devs[i]->access);
502|          /* Make sure it is still a NUL terminated string.  */
503|          fmt_buf[len] = '\0';
504|        }
505|      ret = write_cgroup_file (dirfd, file, fmt_buf, len, err);
506|      if (UNLIKELY (ret < 0))
507|        return ret;
508|    }
509|
510|  for (i = 0; default_devices[i]; i++)
511|    {
512|      ret = write_cgroup_file (dirfd, "devices.allow", default_devices[i], strlen (default_devices[i]), err);
513|      if (UNLIKELY (ret < 0))
514|        return ret;
515|    }
516|
517|  return 0;
518|}
