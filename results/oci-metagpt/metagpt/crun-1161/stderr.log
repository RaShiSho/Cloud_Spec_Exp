700|
701|  if (! memory->swap_present)
702|    return 0;
703|
704|  swap = memory->swap;
705|  if (cgroup2 && memory->swap != -1)
706|    {
707|      if (! memory->limit_present)
708|        return crun_make_error (err, 0, "cannot set swap limit without the memory limit");
709|      if (memory->swap < memory->limit)
710|        return crun_make_error (err, 0, "cannot set memory+swap limit less than the memory limit");
711|
712|      swap -= memory->limit;
713|    }
714|
715|  swap_buf_len = cg_itoa (swap_buf, swap, cgroup2);
716|
717|  ret = write_cgroup_file (dirfd, fname, swap_buf, swap_buf_len, err);
718|  if (ret >= 0)
