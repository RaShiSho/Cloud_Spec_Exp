667|static int
668|cg_itoa (char *buf, int64_t value, bool cgroup2)
669|{
670|  if (! (cgroup2 && value == -1))
671|    return sprintf (buf, "%" PRIi64, value);
672|
673|  memcpy (buf, "max", 4);
