529|    int major;
530|    int minor;
531|    const char *access;
532|  };
533|  struct default_dev_s default_devices[] = {
534|    { 'c', -1, -1, "m" },
535|    { 'b', -1, -1, "m" },
536|    { 'c', 1, 3, "rwm" },
537|    { 'c', 1, 8, "rwm" },
538|    { 'c', 1, 7, "rwm" },
539|    { 'c', 5, 0, "rwm" },
540|    { 'c', 1, 5, "rwm" },
541|    { 'c', 1, 9, "rwm" },
542|    { 'c', 5, 1, "rwm" },
543|    { 'c', 136, -1, "rwm" },
544|    { 'c', 5, 2, "rwm" },
545|  };
546|
547|  program = bpf_program_new (2048);
548|
549|  program = bpf_program_init_dev (program, err);
550|  if (UNLIKELY (program == NULL))
551|    return -1;
552|
553|  for (i = (sizeof (default_devices) / sizeof (default_devices[0])) - 1; i >= 0; i--)
554|    {
555|      program = bpf_program_append_dev (program, default_devices[i].access, default_devices[i].type,
556|                                        default_devices[i].major, default_devices[i].minor, true, err);
557|      if (UNLIKELY (program == NULL))
558|        return -1;
559|    }
560|  for (i = devs_len - 1; i >= 0; i--)
561|    {
562|      char type = 'a';
563|      int minor = -1, major = -1;
564|      if (devs[i]->type != NULL)
565|        type = devs[i]->type[0];
566|
567|      if (devs[i]->major_present)
568|        major = devs[i]->major;
569|      if (devs[i]->minor_present)
570|        minor = devs[i]->minor;
571|
572|      program = bpf_program_append_dev (program, devs[i]->access, type, major, minor, devs[i]->allow, err);
573|      if (UNLIKELY (program == NULL))
574|        return -1;
575|    }
576|
577|  program = bpf_program_complete_dev (program, err);
578|  if (UNLIKELY (program == NULL))
579|    return -1;
580|
581|  ret = libcrun_ebpf_load (program, dirfd, NULL, err);
582|  if (ret < 0)
583|    return ret;
584|
585|  return 0;
