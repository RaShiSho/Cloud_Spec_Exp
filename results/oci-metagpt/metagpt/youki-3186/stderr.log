ner_id);\n089|        let cgroup_config = libcgroups::common::CgroupConfig {\n090|            cgroup_path: cgroups_path,\n091|            systemd_cgroup: self.use_systemd || self.user_ns_config.is_some(),\n092|            container_name: self.container_id.to_owned(),\n093|        };\n094|        let process = self\n095|            .spec\n096|            .process()\n097|            .as_ref()\n098|            .ok_or(MissingSpecError::Process)?;\n099|\n100|        // Need to create the notify socket before we pivot root, since the unix\n101|        // domain socket used here is outside of the rootfs of container. During\n102|        // exec, need to create the socket before we enter into existing mount\n103|        // namespace. We also need to create to socket before entering into the\n104|        // user namespace in the case that the path is located in paths only\n105|        // root can access.\n106|        let notify_listener = NotifyListener::new(&self.notify_path)?;\n107|\n108|        // If Out-of-memory score adjustment is set in specification.  set the score\n109|        // value for the current process check\n110|        // https://dev.to/rrampage/surviving-the-linux-oom-killer-2ki9 for some more\n111|        // information.\n112|        //\n113|        // This has to be done before !dumpable because /proc/self/oom_score_adj\n114|        // is not writeable unless you\'re an privileged user (if !dumpable is\n115|        // set). All children inherit their parent\'s oom_score_adj value on\n116|        // fork(2) so this will always be propagated properly.\n117|        if let Some(oom_score_adj) = process.oom_score_adj() {\n118|            tracing::debug!("Set OOM score to {}", oom_score_adj);\n119|            let mut f = fs::File::create("/proc/self/oom_score_adj").map_err(|err| {\n120|                tracing::error!("failed to open /proc/self/oom_score_adj: {}", err);\n121|                LibcontainerError::OtherIO(err)\n122|            })?;\n123|            f.write_all(oom_score_adj.to_string().as_bytes())\n124|                .map_err(|err| {\n125|                    tracing::error!("failed to write to /proc/self/oom_score_adj: {}", err);\n126|                    LibcontainerError::OtherIO(err)\n127|                })?;\n128|        }\n129|\n130|        // Make the process non-dumpable, to avoid various race conditions that\n131|        // could cause processes in namespaces we\'re joining to access host\n132|        // resources (or potentially execute code).\n133|        //\n134|        // However, if the number of namespaces we are joining is 0, we are not\n135|        // going to be switching to a different security context. Thus setting\n136|        // ourselves to be non-dumpable only breaks things (like rootless\n137|        // containers), which is the recommendation from the kernel folks.\n138|        if linux.namespaces().is_some() {\n139|            prctl::set_dumpable(false).map_err(|e| {\n140|                LibcontainerError::Other(format!(\n141|                    "error in setting dumpable to false : {}",\n142|                    nix::errno::Errno::from_raw(e)\n143|                ))\n144|            })?;\n145|        }\n146|\n147|        // This container_args will be passed to the container processes,\n148|        // therefore we will have to move all the variable by value. Since self\n149|        // is a shared reference, we have to clone these variables here.\n150|        let container_args = ContainerArgs {\n151|            container_type: self.container_type,\n152|            syscall: self.syscall,\n153|            spec: Rc::clone(&self.spec),\n154|            rootfs: self.rootfs.to_owned(),\n155|            console_socket: self.console_socket.as_ref().map(|c| c.as_raw_fd()),\n156|            notify_listener,\n157|            preserve_fds: self.preserve_fds,\n158|            container: self.container.to_owned(),\n159|            user_ns_config: self.user_ns_config.to_owned(),\n160|            cgroup_config,\n161|            detached: self.detached,\n162|            executor: self.executor.clone(),\n163|            no_pivot: self.no_pivot,\n164|            stdin: self.stdin.as_ref().map(|x| x.as_raw_fd()),\n165|            stdout: self.stdout.as_ref().map(|x| x.as_raw_fd()),\n166|            stderr: self.stderr.as_ref().map(|x| x.as_raw_fd()),\n167|            as_sibling: self.as_sibling,\n168|        };\n169|\n170|        let (init_pid, need_to_clean_up_intel_rdt_dir) =\n171|            process::container_main_process::container_main_process(&container_args).map_err(\n172|                |err| {\n173|                    tracing::error!("failed to run container process {}", err);\n174|                    LibcontainerError::MainProcess(err)\n175|                },\n176|            )?;\n177|\n178|        // if file to write the pid to is specified, write pid of the child\n179|        if let Some(pid_file) = &self.pid_file {\n180|            fs::write(pid_file, format!("{init_pid}")).map_err(|err| {\n181|                tracing::error!("failed to write pid to file: {}", err);\n182|                LibcontainerError::OtherIO(err)\n183|            })?;\n184|        }\n185|\n186|        if let Some(container) = &mut self.container {\n187|            // update status and pid of the container process\n188|            container\n189|                .set_status(ContainerStatus::Created)\n190|                .set_creator(nix::unistd::geteuid().as_raw())\n191|                .set_pid(init_pid.as_raw())\n192|                .set_clean_up_intel_rdt_directory(need_to_clean_up_intel_rdt_dir)\n193|                .save()?;\n194|        }\n195|\n196|        if matches!(self.container_type, ContainerType::InitContainer) {\n197|            if let Some(hooks) = self.spec.hooks() {\n198|                hooks::run_hooks(\n199|                    hooks.create_runtime().as_ref(),\n200|                    self.container.as_ref(),\n201|                    None,\n202|                )?\n203|            }\n204|        }\n205|\n206|        Ok(init_pid)\n207|    }\n208|\n209|    fn cleanup_container(&self) -> Result<(), LibcontainerError> {\n210|        let linux = self.spec.linux().as_ref().ok_or(MissingSpecError::Linux)?;\n211|        let cgroups_path = utils::get_cgroup_path(linux.cgroups_path(), &self.container_id);\n212|        let cmanager =\n213|            libcgroups::common::create_cgroup_manager(libcgroups::common::CgroupConfig {\n214|                cgroup_path: cgroups_path,\n215|                systemd_cgroup: self.use_systemd || self.user_ns_config.is_some(),\n216|                container_name: self.container_id.to_string(),\n217|            })?;\n218|\n219|        let mut errors = Vec::new();\n220|\n221|        if let Err(e) = cmanager.remove() {\n222|            tracing::error!(error = ?e, "failed to remove cgroup manager");\n223|            errors.push(e.to_string());\n224|        }\n225|\n226|        if let Some(container) = &self.container {\n227|            if let Some(true) = container.clean_up_intel_rdt_subdirectory() {\n228|                if let Err(e) = delete_resctrl_subdirectory(container.id()) {\n229|                    tracing::error!(id = ?container.id(), error = ?e, "failed to delete resctrl subdirectory");\n230|                    errors.push(e.to_string());\n231|                }\n232|            }\n233|\n234|            if container.root.exists() {\n235|                if let Err(e) = fs::remove_dir_all(&container.root) {\n236|                    tracing::error!(container_root = ?container.root, error = ?e, "failed to delete container root");\n237|                    errors.push(e.to_string());\n238|                }\n239|            }\n240|        }\n241|\n242|        if !errors.is_empty() {\n243|            return Err(LibcontainerError::Other(format!(\n244|                "failed to cleanup container: {}",\n245|                errors.join(";")\n246|            )));\n247|        }\n248|\n249|        Ok(())\n250|    }\n251|}\n'
