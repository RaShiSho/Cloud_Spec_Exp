073|            dup2(stderr, 2).map_err(InitProcessError::NixOther)?;
074|            close(stderr).map_err(InitProcessError::NixOther)?;
075|        }
076|    }
077|
078|    apply_rest_namespaces(&ctx.ns, ctx.spec, ctx.syscall.as_ref())?;
079|
080|    if let Some(true) = ctx.process.no_new_privileges() {
081|        let _ = prctl::set_no_new_privileges(true);
082|    }
083|
