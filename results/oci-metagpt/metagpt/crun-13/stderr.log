644|run_process (char **args, libcrun_error_t *err)
645|{
646|  pid_t pid = fork ();
647|  if (UNLIKELY (pid < 0))
648|    return crun_make_error (err, errno, "fork");
649|  if (pid)
650|    {
651|      int r, status;
652|      r = TEMP_FAILURE_RETRY (waitpid (pid, &status, 0));
653|      if (r < 0)
654|        return crun_make_error (err, errno, "waitpid");
655|      if (WIFEXITED (status) || WIFSIGNALED (status))
656|        return WEXITSTATUS (status);
657|    }
658|
659|  execvp (args[0], args);
660|  _exit (EXIT_FAILURE);
