113|// ignoreCgroupError filters out cgroup-related errors that can be ignored,
114|// because the container is stopped and its cgroup is gone.
115|func (c *Container) ignoreCgroupError(err error) error {
116|	if err == nil {
117|		return nil
118|	}
119|	if errors.Is(err, os.ErrNotExist) && !c.hasInit() && !c.cgroupManager.Exists() {
120|		return nil
121|	}
122|	return err
123|}
