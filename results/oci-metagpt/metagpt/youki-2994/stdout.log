I'll use a Python script to safely remove the hooks block from lines 100-108 and insert it after the container process is created (after `container_main_process` returns and before the status is set to `Created`).

```json
[
    {
        "command_name": "Terminal.run_command",
        "args": {
            "cmd": "cd /home/aludy/scires/Cloud_Spec_Exp/external/worktrees/oci-metagpt/metagpt/youki-2994 && python3 -c \"
import re

filepath = 'crates/libcontainer/src/container/builder_impl.rs'
with open(filepath, 'r') as f:
    content = f.read()

# The hooks block to remove (lines 100-108 in original)
hook_block = '''        if matches!(self.container_type, ContainerType::InitContainer) {
            if let Some(hooks) = self.spec.hooks() {
                hooks::run_hooks(
                    hooks.create_runtime().as_ref(),
                    self.container.as_ref(),
                    None,
                )?
            }
        }
'''

# Insertion point: after the ')?;' line that ends container_main_process call
# Specifically after: '        )?;'
insert_marker = '        )?;'

# Check if hook block exists
if hook_block in content:
    content = content.replace(hook_block, '', 1)
    
    # Find the insertion point (after )?;)
    idx = content.find(insert_marker)
    if idx != -1:
        # Find end of that line (next newline)
        end_of_line = content.find(chr(10), idx) + 1  # after newline
        # Insert the hooks block (with proper indentation matching context after insertion)
        hooks_insert = '''        if matches!(self.container_type, ContainerType::InitContainer) {
            if let Some(hooks) = self.spec.hooks() {
                hooks::run_hooks(
                    hooks.create_runtime().as_ref(),
                    self.container.as_ref(),
                    None,
                )?
            }
        }

'''
        content = content[:end_of_line] + hooks_insert + content[end_of_line:]
        
        with open(filepath, 'w') as f:
            f.write(content)
        print('Successfully moved createRuntime hooks to after container creation')
    else:
        print('Could not find insertion marker')
else:
