064|impl ContainerBuilderImpl {
065|    pub(super) fn create(&mut self) -> Result<Pid, LibcontainerError> {
066|        match self.run_container() {
067|            Ok(pid) => Ok(pid),
068|            Err(outer) => {
069|                // Only the init container should be cleaned up in the case of
070|                // an error.
071|                let cleanup_err = if self.is_init_container() {
072|                    self.cleanup_container().err()
073|                } else {
074|                    None
075|                };
076|
077|                Err(CreateContainerError::new(outer, cleanup_err).into())
078|            }
079|        }
080|    }
081|
082|    fn is_init_container(&self) -> bool {
083|        matches!(self.container_type, ContainerType::InitContainer)
084|    }
085|
086|    fn run_container(&mut self) -> Result<Pid, LibcontainerError> {
087|        let linux = self.spec.linux().as_ref().ok_or(MissingSpecError::Linux)?;
088|        let cgroups_path = utils::get_cgroup_path(linux.cgroups_path(), &self.container_id);
089|        let cgroup_config = libcgroups::common::CgroupConfig {
090|            cgroup_path: cgroups_path,
091|            systemd_cgroup: self.use_systemd || self.user_ns_config.is_some(),
092|            container_name: self.container_id.to_owned(),
093|        };
094|        let process = self
095|            .spec
096|            .process()
097|            .as_ref()
098|            .ok_or(MissingSpecError::Process)?;
099|
100|        if matches!(self.container_type, ContainerType::InitContainer) {
101|            if let Some(hooks) = self.spec.hooks() {
102|                hooks::run_hooks(
103|                    hooks.create_runtime().as_ref(),
104|                    self.container.as_ref(),
105|                    None,
106|                )?
107|            }
108|        }
109|
110|        // Need to create the notify socket before we pivot root, since the unix
111|        // domain socket used here is outside of the rootfs of container. During
112|        // exec, need to create the socket before we enter into existing mount
113|        // namespace. We also need to create to socket before entering into the
114|        // user namespace in the case that the path is located in paths only
115|        // root can access.
116|        let notify_listener = NotifyListener::new(&self.notify_path)?;
117|
118|        // If Out-of-memory score adjustment is set in specification.  set the score
119|        // value for the current process check
120|        // https://dev.to/rrampage/surviving-the-linux-oom-killer-2ki9 for some more
121|        // information.
122|        //
123|        // This has to be done before !dumpable because /proc/self/oom_score_adj
124|        // is not writeable unless you're an privileged user (if !dumpable is
125|        // set). All children inherit their parent's oom_score_adj value on
126|        // fork(2) so this will always be propagated properly.
127|        if let Some(oom_score_adj) = process.oom_score_adj() {
128|            tracing::debug!("Set OOM score to {}", oom_score_adj);
129|            let mut f = fs::File::create("/proc/self/oom_score_adj").map_err(|err| {
130|                tracing::error!("failed to open /proc/self/oom_score_adj: {}", err);
131|                LibcontainerError::OtherIO(err)
132|            })?;
133|            f.write_all(oom_score_adj.to_string().as_bytes())
134|                .map_err(|err| {
135|                    tracing::error!("failed to write to /proc/self/oom_score_adj: {}", err);
136|                    LibcontainerError::OtherIO(err)
137|                })?;
138|        }
139|
140|        // Make the process non-dumpable, to avoid various race conditions that
141|        // could cause processes in namespaces we're joining to access host
142|        // resources (or potentially execute code).
143|        //
144|        // However, if the number of namespaces we are joining is 0, we are not
145|        // going to be switching to a different security context. Thus setting
146|        // ourselves to be non-dumpable only breaks things (like rootless
147|        // containers), which is the recommendation from the kernel folks.
148|        if linux.namespaces().is_some() {
149|            prctl::set_dumpable(false).map_err(|e| {
150|                LibcontainerError::Other(format!(
151|                    "error in setting dumpable to false : {}",
152|                    nix::errno::Errno::from_raw(e)
153|                ))
154|            })?;
155|        }
156|
157|        // This container_args will be passed to the container processes,
158|        // therefore we will have to move all the variable by value. Since self
159|        // is a shared reference, we have to clone these variables here.
160|        let container_args = ContainerArgs {
161|            container_type: self.container_type,
162|            syscall: self.syscall,
163|            spec: Rc::clone(&self.spec),
164|            rootfs: self.rootfs.to_owned(),
165|            console_socket: self.console_socket.as_ref().map(|c| c.as_raw_fd()),
166|            notify_listener,
167|            preserve_fds: self.preserve_fds,
168|            container: self.container.to_owned(),
169|            user_ns_config: self.user_ns_config.to_owned(),
170|            cgroup_config,
171|            detached: self.detached,
172|            executor: self.executor.clone(),
173|            no_pivot: self.no_pivot,
174|            stdin: self.stdin.as_ref().map(|x| x.as_raw_fd()),
175|            stdout: self.stdout.as_ref().map(|x| x.as_raw_fd()),
176|            stderr: self.stderr.as_ref().map(|x| x.as_raw_fd()),
177|            as_sibling: self.as_sibling,
178|        };
179|
180|        let (init_pid, need_to_clean_up_intel_rdt_dir) =
181|            process::container_main_process::container_main_process(&container_args).map_err(
182|                |err| {
183|                    tracing::error!("failed to run container process {}", err);
184|                    LibcontainerError::MainProcess(err)
185|                },
186|            )?;
187|
188|        // if file to write the pid to is specified, write pid of the child
189|        if let Some(pid_file) = &self.pid_file {
190|            fs::write(pid_file, format!("{init_pid}")).map_err(|err| {
191|                tracing::error!("failed to write pid to file: {}", err);
192|                LibcontainerError::OtherIO(err)
193|            })?;
194|        }
195|
196|        if let Some(container) = &mut self.container {
197|            // update status and pid of the container process
198|            container
199|                .set_status(ContainerStatus::Created)
200|                .set_creator(nix::unistd::geteuid().as_raw())
201|                .set_pid(init_pid.as_raw())
202|                .set_clean_up_intel_rdt_directory(need_to_clean_up_intel_rdt_dir)
203|                .save()?;
204|        }
205|
206|        Ok(init_pid)
207|    }
208|
209|    fn cleanup_container(&self) -> Result<(), LibcontainerError> {
210|        let linux = self.spec.linux().as_ref().ok_or(MissingSpecError::Linux)?;
211|        let cgroups_path = utils::get_cgroup_path(linux.cgroups_path(), &self.container_id);
212|        let cmanager =
213|            libcgroups::common::create_cgroup_manager(libcgroups::common::CgroupConfig {
214|                cgroup_path: cgroups_path,
215|                systemd_cgroup: self.use_systemd || self.user_ns_config.is_some(),
216|                container_name: self.container_id.to_string(),
217|            })?;
218|
219|        let mut errors = Vec::new();
220|
221|        if let Err(e) = cmanager.remove() {
222|            tracing::error!(error = ?e, "failed to remove cgroup manager");
223|            errors.push(e.to_string());
224|        }
225|
226|        if let Some(container) = &self.container {
227|            if let Some(true) = container.clean_up_intel_rdt_subdirectory() {
228|                if let Err(e) = delete_resctrl_subdirectory(container.id()) {
229|                    tracing::error!(id = ?container.id(), error = ?e, "failed to delete resctrl subdirectory");
230|                    errors.push(e.to_string());
231|                }
232|            }
233|
234|            if container.root.exists() {
235|                if let Err(e) = fs::remove_dir_all(&container.root) {
236|                    tracing::error!(container_root = ?container.root, error = ?e, "failed to delete container root");
237|                    errors.push(e.to_string());
238|                }
239|            }
240|        }
241|
242|        if !errors.is_empty() {
243|            return Err(LibcontainerError::Other(format!(
244|                "failed to cleanup container: {}",
245|                errors.join(";")
246|            )));
247|        }
248|
249|        Ok(())
250|    }
251|}
