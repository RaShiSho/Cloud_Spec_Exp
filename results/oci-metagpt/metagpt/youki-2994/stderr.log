n086|        ProcessError::IntermediateProcessFailed(err)\n087|    })?;\n088|\n089|    // Close down unused fds. The corresponding fds are duplicated to the\n090|    // child process during clone.\n091|    main_sender.close().map_err(|err| {\n092|        tracing::error!("failed to close unused sender: {}", err);\n093|        err\n094|    })?;\n095|\n096|    let (mut inter_sender, inter_receiver) = inter_chan;\n097|    #[cfg(feature = "libseccomp")]\n098|    let (mut init_sender, init_receiver) = init_chan;\n099|    #[cfg(not(feature = "libseccomp"))]\n100|    let (init_sender, init_receiver) = init_chan;\n101|\n102|    // If creating a container with new user namespace, the intermediate process will ask\n103|    // the main process to set up uid and gid mapping, once the intermediate\n104|    // process enters into a new user namespace.\n105|    if let Some(config) = &container_args.user_ns_config {\n106|        main_receiver.wait_for_mapping_request()?;\n107|        setup_mapping(config, intermediate_pid)?;\n108|        inter_sender.mapping_written()?;\n109|    }\n110|\n111|    // At this point, we don\'t need to send any message to intermediate process anymore,\n112|    // so we want to close this sender at the earliest point.\n113|    inter_sender.close().map_err(|err| {\n114|        tracing::error!("failed to close unused intermediate sender: {}", err);\n115|        err\n116|    })?;\n117|\n118|    // The intermediate process will send the init pid once it forks the init\n119|    // process.  The intermediate process should exit after this point.\n120|    let init_pid = main_receiver.wait_for_intermediate_ready()?;\n121|    let mut need_to_clean_up_intel_rdt_subdirectory = false;\n122|\n123|    if let Some(linux) = container_args.spec.linux() {\n124|        #[cfg(feature = "libseccomp")]\n125|        if let Some(seccomp) = linux.seccomp() {\n126|            let state = crate::container::ContainerProcessState {\n127|                oci_version: container_args.spe