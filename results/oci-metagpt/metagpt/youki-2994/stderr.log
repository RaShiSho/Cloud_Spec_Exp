from the path.  For example, path\n051|            // may be "/usr/bin/true" and arg0 is set to "true". However, rust\n052|            // command differentiates arg0 from args, where rust command arg\n053|            // doesn\'t include arg0. So we have to make the split arg0 from the\n054|            // rest of args.\n055|            if let Some((arg0, args)) = hook.args().as_ref().and_then(|a| a.split_first()) {\n056|                tracing::debug!("run_hooks arg0: {:?}, args: {:?}", arg0, args);\n057|                hook_command.arg0(arg0).args(args)\n058|            } else {\n059|                hook_command.arg0(hook.path().display().to_string())\n060|            };\n061|\n062|            let envs: HashMap<String, String> = if let Some(env) = hook.env() {\n063|                utils::parse_env(env)\n064|            } else {\n065|                HashMap::new()\n066|            };\n067|            tracing::debug!("run_hooks envs: {:?}", envs);\n068|\n069|            let mut hook_process = hook_command\n070|                .env_clear()\n071|                .envs(envs)\n072|                .stdin(process::Stdio::piped())\n073|                .spawn()\n074|                .map_err(HookError::CommandExecute)?;\n075|            let hook_process_pid = Pid::from_raw(hook_process.id() as i32);\n076|            // Based on the OCI spec, we need to pipe the container state into\n077|            // the hook command through stdin.\n078|            if let Some(stdin) = &mut hook_process.stdin {\n079|                // We want to ignore BrokenPipe here. A BrokenPipe indicates\n080|                // either the hook is crashed/errored or it ran successfully.\n081|                // Either way, this is an indication that the hook command\n082|                // finished execution.  If the hook command was successful,\n083|                // which we will check later in this function, we should not\n084|                // fail this step here. We still want to check for all the oth