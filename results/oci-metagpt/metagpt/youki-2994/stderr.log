le::tempdir()?;\n216|\n217|            let default_container: Container = Default::default();\n218|            let hook = HookBuilder::default()\n219|                .path("bash")\n220|                .args(vec![\n221|                    String::from("bash"),\n222|                    String::from("-c"),\n223|                    format!("test $(pwd) = {:?}", tmp.path()),\n224|                ])\n225|                .build()?;\n226|            let hooks = Some(vec![hook]);\n227|            run_hooks(hooks.as_ref(), Some(&default_container), Some(tmp.path()))\n228|                .context("Failed pwd test")?;\n229|        }\n230|\n231|        Ok(())\n232|    }\n233|\n234|    #[test]\n235|    #[serial]\n236|    // This will test executing hook with a timeout. Since the timeout is set in\n237|    // secs, minimally, the test will run for 1 second to trigger the timeout.\n238|    fn test_run_hook_timeout() -> Result<()> {\n239|        let default_container: Container = Default::default();\n240|        // We use `tail -f /dev/null` here to simulate a hook command that hangs.\n241|        let hook = HookBuilder::default()\n242|            .path("tail")\n243|            .args(vec![\n244|                String::from("tail"),\n245|                String::from("-f"),\n246|                String::from("/dev/null"),\n247|            ])\n248|            .timeout(1)\n249|            .build()?;\n250|        let hooks = Some(vec![hook]);\n251|        match run_hooks(hooks.as_ref(), Some(&default_container), None) {\n252|            Ok(_) => {\n253|                bail!("The test expects the hook to error out with timeout. Should not execute cleanly");\n254|            }\n255|            Err(HookError::Timeout) => {}\n256|            Err(err) => {\n257|                bail!(\n258|                    "The test expects the hook to error out with timeout. Got error: {}",\n259|                    err\n260|                );\n261|            }\n262|        };\n263|\n264|        Ok(())\n265