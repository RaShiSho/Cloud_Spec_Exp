53|\n054|    pub fn with_detach(mut self, detached: bool) -> Self {\n055|        self.detached = detached;\n056|        self\n057|    }\n058|\n059|    pub fn with_no_pivot(mut self, no_pivot: bool) -> Self {\n060|        self.no_pivot = no_pivot;\n061|        self\n062|    }\n063|\n064|    /// Creates a new container\n065|    pub fn build(self) -> Result<Container, LibcontainerError> {\n066|        let spec = self.load_spec()?;\n067|        let container_dir = self.create_container_dir()?;\n068|\n069|        let mut container = self.create_container_state(&container_dir)?;\n070|        container\n071|            .set_systemd(self.use_systemd)\n072|            .set_annotations(spec.annotations().clone());\n073|\n074|        let notify_path = container_dir.join(NOTIFY_FILE);\n075|        // convert path of root file system of the container to absolute path\n076|        let rootfs = fs::canonicalize(spec.root().as_ref().ok_or(MissingSpecError::Root)?.path())\n077|            .map_err(LibcontainerError::OtherIO)?;\n078|\n079|        // if socket file path is given in commandline options,\n080|        // get file descriptors of console socket\n081|        let csocketfd = if let Some(console_socket) = &self.base.console_socket {\n082|            Some(tty::setup_console_socket(\n083|                &container_dir,\n084|                console_socket,\n085|                "console-socket",\n086|            )?)\n087|        } else {\n088|            None\n089|        };\n090|\n091|        let user_ns_config = UserNamespaceConfig::new(&spec)?;\n092|\n093|        let config = YoukiConfig::from_spec(&spec, container.id())?;\n094|        config.save(&container_dir).map_err(|err| {\n095|            tracing::error!(?container_dir, "failed to save config: {}", err);\n096|            err\n097|        })?;\n098|\n099|        let mut builder_impl = ContainerBuilderImpl {\n100|            container_type: ContainerType::InitContainer,\n101|            syscall: self.base.syscall,\n102|            container_id: self.base.container_id,\n103|            pid_file: self.base.pid_file,\n104|            console_socket: csocketfd,\n105|            use_systemd: self.use_systemd,\n106|            spec: Rc::new(spec),\n107|            rootfs,\n108|            user_ns_config,\n109|            notify_path,\n110|            container: Some(container.clone()),\n111|            preserve_fds: self.base.preserve_fds,\n112|            detached: self.detached,\n113|            executor: self.base.executor,\n114|            no_pivot: self.no_pivot,\n115|            stdin: self.base.stdin,\n116|            stdout: self.base.stdout,\n117|            stderr: self.base.stderr,\n118|            as_sibling: self.as_sibling,\n119|        };\n120|\n121|        builder_impl.create()?;\n122|\n123|        container.refresh_state()?;\n124|\n125|        Ok(container)\n126|    }\n127|\n128|    fn create_container_dir(&self) -> Result<PathBuf, LibcontainerError> {\n129|        let container_dir = self.base.root_path.join(&self.base.container_id);\n130|        tracing::debug!("container directory will be {:?}", container_dir);\n131|\n132|        if container_dir.exists() {\n133|            tracing::error!(id = self.base.container_id, dir = ?container_dir, "container already exists");\n134|            return Err(LibcontainerError::Exist);\n135|        }\n136|\n137|        std::fs::create_dir_all(&container_dir).map_err(|err| {\n138|            tracing::error!(\n139|                ?container_dir,\n140|                "failed to create container directory: {}",\n141|                err\n142|            );\n143|            LibcontainerError::OtherIO(err)\n144|        })?;\n145|\n146|        Ok(container_dir)\n147|    }\n148|\n149|    fn load_spec(&self) -> Result<Spec, LibcontainerError> {\n150|        let source_spec_path = self.bundle.join("config.json");\n151|        let mut spec = Spec::load(source_spec_path)?;\n152|        Self::validate_spec(&spec)?;\n153|\n154|        spec.canonicalize_rootfs(&self.bundle).map_err(|err| {\n155|            tracing::error!(bundle = ?self.bundle, "failed to canonicalize rootfs: {}", err);\n156|            err\n157|        })?;\n158|\n159|        Ok(spec)\n160|    }\n161|\n162|    fn validate_spec(spec: &Spec) -> Result<(), LibcontainerError> {\n163|        let version = spec.version();\n164|        if !version.starts_with("1.") {\n165|            tracing::error!(\n166|                "runtime spec has incompatible version \'{}\'. Only 1.X.Y is supported",\n167|                spec.version()\n168|            );\n169|            Err(ErrInvalidSpec::UnsupportedVersion)?;\n170|        }\n171|\n172|        if let Some(process) = spec.process() {\n173|            if let Some(profile) = process.apparmor_profile() {\n174|                let apparmor_is_enabled = apparmor::is_enabled().map_err(|err| {\n175|                    tracing::error!(?err, "failed to check if apparmor is enabled");\n176|                    LibcontainerError::OtherIO(err)\n177|                })?;\n178|                if !apparmor_is_enabled {\n179|                    tracing::error!(?profile,\n180|                        "apparmor profile exists in the spec, but apparmor is not activated on this system");\n181|                    Err(ErrInvalidSpec::AppArmorNotEnabled)?;\n182|                }\n183|            }\n184|\n185|            if let Some(io_priority) = process.io_priority() {\n186|                let priority = io_priority.priority();\n187|                let iop_class_res = serde_json::to_string(&io_priority.class());\n188|                match iop_class_res {\n189|                    Ok(iop_class) => {\n190|                        if !(0..=7).contains(&priority) {\n191|                            tracing::error!(?priority, "io priority \'{}\' not between 0 and 7 (inclusive), class \'{}\' not in (IO_PRIO_CLASS_RT,IO_PRIO_CLASS_BE,IO_PRIO_CLASS_IDLE)",priority, iop_class);\n192|                            Err(ErrInvalidSpec::IoPriority)