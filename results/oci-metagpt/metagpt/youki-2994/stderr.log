109|        // If Out-of-memory score adjustment is set in specification.  set the score
110|        // value for the current process check
111|        // https://dev.to/rrampage/surviving-the-linux-oom-killer-2ki9 for some more
112|        // information.
113|        //
114|        // This has to be done before !dumpable because /proc/self/oom_score_adj
115|        // is not writeable unless you're an privileged user (if !dumpable is
116|        // set). All children inherit their parent's oom_score_adj value on
117|        // fork(2) so this will always be propagated properly.
118|        if let Some(oom_score_adj) = process.oom_score_adj() {
119|            tracing::debug!("Set OOM score to {}", oom_score_adj);
120|            let mut f = fs::File::create("/proc/self/oom_score_adj").map_err(|err| {
121|                tracing::error!("failed to open /proc/self/oom_score_adj: {}", err);
122|                LibcontainerError::OtherIO(err)
123|            })?;
124|            f.write_all(oom_score_adj.to_string().as_bytes())
125|                .map_err(|err| {
126|                    tracing::error!("failed to write to /proc/self/oom_score_adj: {}", err);
127|                    LibcontainerError::OtherIO(err)
128|                })?;
129|        }
130|
131|        // Make the process non-dumpable, to avoid various race conditions that
132|        // could cause processes in namespaces we're joining to access host
133|        // resources (or potentially execute code).
134|        //
135|        // However, if the number of namespaces we are joining is 0, we are not
136|        // going to be switching to a different security context. Thus setting
137|        // ourselves to be non-dumpable only breaks things (like rootless
138|        // containers), which is the recommendation from the kernel folks.
139|        if linux.namespaces().is_some() {
140|            prctl::set_dumpable(false).map_err(|e| {
141|                LibcontainerError::Other(format!(
142|                    "error in setting dumpable to false : {}",
143|                    nix::errno::Errno::from_raw(e)
144|                ))
145|            })?;
146|        }
147|
148|        // This container_args will be passed to the container processes,
149|        // therefore we will have to move all the variable by value. Since self
150|        // is a shared reference, we have to clone these variables here.
151|        let container_args = ContainerArgs {
152|            container_type: self.container_type,
153|            syscall: self.syscall,
154|            spec: Rc::clone(&self.spec),
155|            rootfs: self.rootfs.to_owned(),
156|            console_socket: self.console_socket.as_ref().map(|c| c.as_raw_fd()),
157|            notify_listener,
158|            preserve_fds: self.preserve_fds,
159|            container: self.container.to_owned(),
160|            user_ns_config: self.user_ns_config.to_owned(),
161|            cgroup_config,
162|            detached: self.detached,
163|            executor: self.executor.clone(),
164|            no_pivot: self.no_pivot,
165|            stdin: self.stdin.as_ref().map(|x| x.as_raw_fd()),
166|            stdout: self.stdout.as_ref().map(|x| x.as_raw_fd()),
167|            stderr: self.stderr.as_ref().map(|x| x.as_raw_fd()),
168|            as_sibling: self.as_sibling,
169|        };
170|
171|        let (init_pid, need_to_clean_up_intel_rdt_dir) =
172|            process::container_main_process::container_main_process(&container_args).map_err(
173|                |err| {
174|                    tracing::error!("failed to run container process {}", err);
175|                    LibcontainerError::MainProcess(err)
176|                },
177|            )?;
178|        if matches!(self.container_type, ContainerType::InitContainer) {
179|            if let Some(hooks) = self.spec.hooks() {
180|                hooks::run_hooks(
181|                    hooks.create_runtime().as_ref(),
182|                    self.container.as_ref(),
183|                    None,
184|                )?
185|            }
186|        }
187|
188|
189|        // if file to write the pid to is specified, write pid of the child
190|        if let Some(pid_file) = &self.pid_file {
191|            fs::write(pid_file, format!("{init_pid}")).map_err(|err| {
192|                tracing::error!("failed to write pid to file: {}", err);
193|                LibcontainerError::OtherIO(err)
194|            })?;
195|        }
196|
197|        if let Some(container) = &mut self.container {
198|            // update status and pid of the container process
199|            container
200|                .set_status(ContainerStatus::Created)
201|                .set_creator(nix::unistd::geteuid().as_raw())
202|                .set_pid(init_pid.as_raw())
203|                .set_clean_up_intel_rdt_directory(need_to_clean_up_intel_rdt_dir)
204|                .save()?;
205|        }
206|
207|        Ok(init_pid)
208|    }
209|
210|    fn cleanup_container(&self) -> Result<(), LibcontainerError> {
211|        let linux = self.spec.linux().as_ref().ok_or(MissingSpecError::Linux)?;
212|        let cgroups_path = utils::get_cgroup_path(linux.cgroups_path(), &self.container_id);
213|        let cmanager =
214|            libcgroups::common::create_cgroup_manager(libcgroups::common::CgroupConfig {
215|                cgroup_path: cgroups_path,
216|                systemd_cgroup: self.use_systemd || self.user_ns_config.is_some(),
217|                container_name: self.container_id.to_string(),
218|            })?;
219|
220|        let mut errors = Vec::new();
221|
222|        if let Err(e) = cmanager.remove() {
223|            tracing::error!(error = ?e, "failed to remove cgroup manager");
224|            errors.push(e.to_string());
225|        }
226|
227|        if let Some(container) = &self.container {
228|            if let Some(true) = container.clean_up_intel_rdt_subdirectory() {
229|                if let Err(e) = delete_resctrl_subdirectory(container.id()) {
230|                    tracing::error!(id = ?container.id(), error = ?e, "failed to delete resctrl subdirectory");
231|                    errors.push(e.to_string());
232|                }
233|            }
234|
235|            if container.root.exists() {
236|                if let Err(e) = fs::remove_dir_all(&container.root) {
237|                    tracing::error!(container_root = ?container.root, error = ?e, "failed to delete container root");
238|                    errors.push(e.to_string());
239|                }
240|            }
241|        }
242|
243|        if !errors.is_empty() {
244|            return Err(LibcontainerError::Other(format!(
245|                "failed to cleanup container: {}",
246|                errors.join(";")
247|            )));
248|        }
249|
250|        Ok(())
251|    }
252|}
