080|fn clone3(cb: &mut CloneCb, flags: u64, exit_signal: Option<u64>) -> Result<Pid, CloneError> {
081|    #[repr(C)]
082|    struct clone3_args {
083|        flags: u64,
084|        pidfd: u64,
085|        child_tid: u64,
086|        parent_tid: u64,
087|        exit_signal: u64,
088|        stack: u64,
089|        stack_size: u64,
090|        tls: u64,
091|        set_tid: u64,
092|        set_tid_size: u64,
093|        cgroup: u64,
094|    }
095|    let mut args = clone3_args {
096|        flags,
097|        pidfd: 0,
098|        child_tid: 0,
099|        parent_tid: 0,
100|        exit_signal: exit_signal.unwrap_or(0),
101|        stack: 0,
102|        stack_size: 0,
103|        tls: 0,
104|        set_tid: 0,
105|        set_tid_size: 0,
106|        cgroup: 0,
107|    };
108|    let args_ptr = &mut args as *mut clone3_args;
109|    let args_size = std::mem::size_of::<clone3_args>();
110|    // For now, we can only use clone3 as a kernel syscall. Libc wrapper is not
111|    // available yet. This can have undefined behavior because libc authors do
112|    // not like people calling kernel syscall to directly create processes. Libc
113|    // does perform additional bookkeeping when calling clone or fork. So far,
114|    // we have not observed any issues with calling clone3 directly, but we
115|    // should keep an eye on it.
116|    match unsafe { libc::syscall(libc::SYS_clone3, args_ptr, args_size) } {
117|        -1 => Err(CloneError::Clone(nix::Error::last())),
118|        0 => {
119|            // Inside the cloned process, we execute the callback and exit with
120|            // the return code.
121|            std::process::exit(cb());
122|        }
123|        ret if ret >= 0 => Ok(Pid::from_raw(ret as i32)),
124|        ret => Err(CloneError::UnknownErrno(ret as i32)),
125|    }
