d to ensure the path exists before we write the mapping.\n272|                // The path requires the pid we use, so we can only do do after\n273|                // obtaining the child pid here.\n274|                id_mapper.ensure_uid_path(&child)?;\n275|                setup_mapping(&ns_config, child)?;\n276|                let line = fs::read_to_string(id_mapper.get_uid_path(&child))?;\n277|                let split_lines = line.split_whitespace();\n278|                for (act, expect) in split_lines.zip([\n279|                    uid_mapping.container_id().to_string(),\n280|                    uid_mapping.host_id().to_string(),\n281|                    uid_mapping.size().to_string(),\n282|                ]) {\n283|                    assert_eq!(act, expect);\n284|                }\n285|                child_sender.mapping_written()?;\n286|                child_sender.close()?;\n287|            }\n288|            unistd::ForkResult::Child => {\n289|                prctl::set_dumpable(true).unwrap();\n290|                unshare(CloneFlags::CLONE_NEWUSER)?;\n291|                parent_sender.identifier_mapping_request()?;\n292|                parent_sender.close()?;\n293|                child_receiver.wait_for_mapping_ack()?;\n294|                child_receiver.close()?;\n295|                std::process::exit(0);\n296|            }\n297|        }\n298|        Ok(())\n299|    }\n300|\n301|    #[test]\n302|    #[serial]\n303|    fn setup_gid_mapping_should_succeed() -> Result<()> {\n304|        let gid_mapping = LinuxIdMappingBuilder::default()\n305|            .host_id(getgid())\n306|            .container_id(0u32)\n307|            .size(1u32)\n308|            .build()?;\n309|        let gid_mappings = vec![gid_mapping];\n310|        let tmp = tempfile::tempdir()?;\n311|        let id_mapper = UserNamespaceIDMapper::new_test(tmp.path().to_path_buf());\n312|        let ns_config = UserNamespaceConfig {\n313|            gid_mappings: Some(gid_mappings),\n314|    