       return;\n043|        }\n044|\n045|        // empty access match nothing, just discard this rule\n046|        if rule.access().is_none() {\n047|            return;\n048|        }\n049|\n050|        self.rules.push(rule.clone());\n051|    }\n052|}\n053|\n054|#[cfg(test)]\n055|mod tests {\n056|    use oci_spec::runtime::LinuxDeviceCgroupBuilder;\n057|\n058|    use super::*;\n059|\n060|    #[test]\n061|    fn test_with_default_allow() {\n062|        // act\n063|        let emulator = Emulator::with_default_allow(true);\n064|\n065|        // assert\n066|        assert_eq!(emulator.rules.len(), 0);\n067|        assert!(emulator.default_allow);\n068|    }\n069|\n070|    #[test]\n071|    fn test_type_a_rule() {\n072|        // arrange\n073|        let mut emulator = Emulator::with_default_allow(false);\n074|        let cgroup = LinuxDeviceCgroupBuilder::default()\n075|            .typ(LinuxDeviceType::A)\n076|            .build()\n077|            .unwrap();\n078|\n079|        // act\n080|        emulator.add_rule(&cgroup);\n081|\n082|        // assert\n083|        assert_eq!(emulator.rules.len(), 0);\n084|        assert!(!emulator.default_allow);\n085|    }\n086|\n087|    #[test]\n088|    fn test_add_empty_rule() {\n089|        // arrange\n090|        let mut emulator = Emulator::with_default_allow(false);\n091|        let cgroup = LinuxDeviceCgroupBuilder::default().build().unwrap();\n092|\n093|        // act\n094|        emulator.add_rule(&cgroup);\n095|\n096|        // assert\n097|        assert_eq!(emulator.rules.len(), 0);\n098|        assert!(!emulator.default_allow);\n099|    }\n100|\n101|    #[test]\n102|    fn test_add_some_rule() {\n103|        // arrange\n104|        let mut emulator = Emulator::with_default_allow(false);\n105|        let permission: &str = "PERMISSION";\n106|        let cgroup = LinuxDeviceCgroupBuilder::default()\n107|            .typ(LinuxDeviceType::B)\n108|            .access(permission)\n109|            .build()\n110|            .unwrap();\n111|\n112|        // act\n113|        emulator.add_rule(&cgroup);\n114|\n115|        // assert\n116|        let top_rule = emulator.rules.first().unwrap();\n117|        assert_eq!(top_rule.access(), &Some(permission.to_string()));\n118|        assert!(!emulator.default_allow);\n119|    }\n120|}\n'
