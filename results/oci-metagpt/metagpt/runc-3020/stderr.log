214|
215|		if intelrdt.IsCATEnabled() && config.IntelRdt.L3CacheSchema == "" {
216|			return errors.New("Intel RDT/CAT is enabled and intelRdt is specified in config, but intelRdt.l3CacheSchema is empty")
