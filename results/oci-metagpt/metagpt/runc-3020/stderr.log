061|// rootfs validates if the rootfs is an absolute path and is not a symlink
062|// to the container's root filesystem.
063|func (v *ConfigValidator) rootfs(config *configs.Config) error {
064|	if _, err := os.Stat(config.Rootfs); err != nil {
065|		if os.IsNotExist(err) {
066|			return fmt.Errorf("rootfs (%s) does not exist", config.Rootfs)
067|		}
068|		return err
069|	}
070|	cleaned, err := filepath.Abs(config.Rootfs)
071|	if err != nil {
072|		return err
073|	}
074|	if cleaned, err = filepath.EvalSymlinks(cleaned); err != nil {
075|		return err
076|	}
077|	if filepath.Clean(config.Rootfs) != cleaned {
078|		return fmt.Errorf("%s is not an absolute path or is a symlink", config.Rootfs)
079|	}
080|	return nil
081|}
