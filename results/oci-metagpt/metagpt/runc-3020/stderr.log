175|				}
176|				hostnet, hostnetErr = isHostNetNS(path)
177|			})
178|			if hostnetErr != nil {
179|				return hostnetErr
180|			}
181|			if hostnet {
182|				return fmt.Errorf("sysctl %q not allowed in host network namespace", s)
183|			}
184|			continue
185|		}
186|		if config.Namespaces.Contains(configs.NEWUTS) {
187|			switch s {
188|			case "kernel.domainname":
189|				// This is namespaced and there's no explicit OCI field for it.
190|				continue
191|			case "kernel.hostname":
192|				// This is namespaced but there's a conflicting (dedicated) OCI field for it.
193|				return fmt.Errorf("sysctl %q is not allowed as it conflicts with the OCI %q field", s, "hostname")
194|			}
195|		}
196|		return fmt.Errorf("sysctl %q is not in a separate kernel namespace", s)
197|	}
198|
199|	return nil
200|}
201|
202|func (v *ConfigValidator) intelrdt(config *configs.Config) error {
203|	if config.IntelRdt != nil {
204|		if !intelrdt.IsCATEnabled() && !intelrdt.IsMBAEnabled() {
205|			return errors.New("intelRdt is specified in config, but Intel RDT is not supported or enabled")
206|		}
207|
208|		if !intelrdt.IsCATEnabled() && config.IntelRdt.L3CacheSchema != "" {
209|			return errors.New("intelRdt.l3CacheSchema is specified in config, but Intel RDT/CAT is not enabled")
210|		}
211|		if !intelrdt.IsMBAEnabled() && config.IntelRdt.MemBwSchema != "" {
212|			return errors.New("intelRdt.memBwSchema is specified in config, but Intel RDT/MBA is not enabled")
213|		}
214|
215|		if intelrdt.IsCATEnabled() && config.IntelRdt.L3CacheSchema == "" {
216|			return errors.New("Intel RDT/CAT is enabled and intelRdt is specified in config, but intelRdt.l3CacheSchema is empty")
217|		}
218|		if intelrdt.IsMBAEnabled() && config.IntelRdt.MemBwSchema == "" {
219|			return errors.New("Intel RDT/MBA is enabled and intelRdt is specified in config, but intelRdt.memBwSchema is empty")
220|		}
221|	}
222|
223|	return nil
224|}
225|
226|func (v *ConfigValidator) cgroups(config *configs.Config) error {
227|	c := config.Cgroups
228|	if c == nil {
229|		return nil
230|	}
231|
232|	if (c.Name != "" || c.Parent != "") && c.Path != "" {
233|		return fmt.Errorf("cgroup: either Path or Name and Parent should be used, got %+v", c)
234|	}
235|
236|	r := c.Resources
237|	if r == nil {
238|		return nil
239|	}
240|
241|	if !cgroups.IsCgroup2UnifiedMode() && r.Unified != nil {
242|		return cgroups.ErrV1NoUnified
243|	}
244|
245|	if cgroups.IsCgroup2UnifiedMode() {
246|		_, err := cgroups.ConvertMemorySwapToCgroupV2Value(r.MemorySwap, r.Memory)
247|		if err != nil {
248|			return err
249|		}
250|	}
251|
252|	return nil
253|}
254|
255|func (v *ConfigValidator) mounts(config *configs.Config) error {
256|	for _, m := range config.Mounts {
257|		if !filepath.IsAbs(m.Destination) {
258|			return fmt.Errorf("invalid mount %+v: mount destination not absolute", m)
259|		}
260|	}
261|
262|	return nil
263|}
264|
265|func isHostNetNS(path string) (bool, error) {
266|	const currentProcessNetns = "/proc/self/ns/net"
267|
268|	var st1, st2 unix.Stat_t
269|
270|	if err := unix.Stat(currentProcessNetns, &st1); err != nil {
271|		return false, fmt.Errorf("unable to stat %q: %s", currentProcessNetns, err)
272|	}
273|	if err := unix.Stat(path, &st2); err != nil {
274|		return false, fmt.Errorf("unable to stat %q: %s", path, err)
275|	}
276|
277|	return (st1.Dev == st2.Dev) && (st1.Ino == st2.Ino), nil
278|}
