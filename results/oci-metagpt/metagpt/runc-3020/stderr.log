134|// sysctl validates that the specified sysctl keys are valid or not.
135|// /proc/sys isn't completely namespaced and depending on which namespaces
136|// are specified, a subset of sysctls are permitted.
137|func (v *ConfigValidator) sysctl(config *configs.Config) error {
138|	validSysctlMap := map[string]bool{
139|		"kernel.msgmax":          true,
140|		"kernel.msgmnb":          true,
141|		"kernel.msgmni":          true,
142|		"kernel.sem":             true,
143|		"kernel.shmall":          true,
144|		"kernel.shmmax":          true,
145|		"kernel.shmmni":          true,
146|		"kernel.shm_rmid_forced": true,
147|	}
148|
149|	var (
150|		netOnce    sync.Once
151|		hostnet    bool
152|		hostnetErr error
153|	)
154|
155|	for s := range config.Sysctl {
156|		if validSysctlMap[s] || strings.HasPrefix(s, "fs.mqueue.") {
157|			if config.Namespaces.Contains(configs.NEWIPC) {
158|				continue
159|			} else {
160|				return fmt.Errorf("sysctl %q is not allowed in the hosts ipc namespace", s)
161|			}
162|		}
163|		if strings.HasPrefix(s, "net.") {
164|			// Is container using host netns?
165|			// Here "host" means "current", not "initial".
166|			netOnce.Do(func() {
167|				if !config.Namespaces.Contains(configs.NEWNET) {
168|					hostnet = true
169|					return
170|				}
171|				path := config.Namespaces.PathOf(configs.NEWNET)
172|				if path == "" {
173|					// own netns, so hostnet = false
174|					return
175|				}
176|				hostnet, hostnetErr = isHostNetNS(path)
177|			})
178|			if hostnetErr != nil {
179|				return hostnetErr
180|			}
181|			if hostnet {
182|				return fmt.Errorf("sysctl %q not allowed in host network namespace", s)
183|			}
184|			continue
185|		}
186|		if config.Namespaces.Contains(configs.NEWUTS) {
187|			switch s {
188|			case "kernel.domainname":
189|				// This is namespaced and there's no explicit OCI field for it.
190|				continue
191|			case "kernel.hostname":
192|				// This is namespaced but there's a conflicting (dedicated) OCI field for it.
193|				return fmt.Errorf("sysctl %q is not allowed as it conflicts with the OCI %q field", s, "hostname")
194|			}
195|		}
196|		return fmt.Errorf("sysctl %q is not in a separate kernel namespace", s)
197|	}
198|
199|	return nil
200|}
