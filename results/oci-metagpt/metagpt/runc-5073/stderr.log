rnel >= 4.15 .\n155|//\n156|// https://github.com/torvalds/linux/commit/ebc614f687369f9df99828572b1d85a7c2de3d92\n157|func loadAttachCgroupDeviceFilter(insts asm.Instructions, license string, dirFd int) (func() error, error) {\n158|\t// Increase `ulimit -l` limit to avoid BPF_PROG_LOAD error (#2167).\n159|\t// This limit is not inherited into the container.\n160|\tmemlockLimit := &unix.Rlimit{\n161|\t\tCur: unix.RLIM_INFINITY,\n162|\t\tMax: unix.RLIM_INFINITY,\n163|\t}\n164|\t_ = unix.Setrlimit(unix.RLIMIT_MEMLOCK, memlockLimit)\n165|\n166|\t// Get the list of existing programs.\n167|\toldProgs, err := findAttachedCgroupDeviceFilters(dirFd)\n168|\tif err != nil {\n169|\t\treturn nilCloser, err\n170|\t}\n171|\tuseReplaceProg := haveBpfProgReplace() && len(oldProgs) == 1\n172|\n173|\t// Generate new program.\n174|\tspec := &ebpf.ProgramSpec{\n175|\t\tType:         ebpf.CGroupDevice,\n176|\t\tInstructions: insts,\n177|\t\tLicense:      license,\n178|\t}\n179|\tprog, err := ebpf.NewProgram(spec)\n180|\tif err != nil {\n181|\t\treturn nilCloser, err\n182|\t}\n183|\n184|\t// If there is only one old program, we can just replace it directly.\n185|\n186|\tattachProgramOptions := link.RawAttachProgramOptions{\n187|\t\tTarget:  dirFd,\n188|\t\tProgram: prog,\n189|\t\tAttach:  ebpf.AttachCGroupDevice,\n190|\t\tFlags:   unix.BPF_F_ALLOW_MULTI,\n191|\t}\n192|\n193|\tif useReplaceProg {\n194|\t\tattachProgramOptions.Anchor = link.ReplaceProgram(oldProgs[0])\n195|\t}\n196|\terr = link.RawAttachProgram(attachProgramOptions)\n197|\tif err != nil {\n198|\t\treturn nilCloser, fmt.Errorf("failed to call BPF_PROG_ATTACH (BPF_CGROUP_DEVICE, BPF_F_ALLOW_MULTI): %w", err)\n199|\t}\n200|\tcloser := func() error {\n201|\t\terr = link.RawDetachProgram(link.RawDetachProgramOptions{\n202|\t\t\tTarget:  dirFd,\n203|\t\t\tProgram: prog,\n204|\t\t\tAttach:  ebpf.AttachCGroupDevice,\n205|\t\t})\n206|\t\tif err != nil {\n207|\t\t\treturn fmt.Errorf("failed to call BPF_PROG_DETACH (BPF_CGROUP_DEVICE)