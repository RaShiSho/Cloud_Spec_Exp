d(transitionRules, &devices.Rule{\n362|\t\t\t\tType:        meta.node,\n363|\t\t\t\tMajor:       meta.major,\n364|\t\t\t\tMinor:       meta.minor,\n365|\t\t\t\tPermissions: gainedPerms,\n366|\t\t\t\tAllow:       !target.defaultAllow,\n367|\t\t\t})\n368|\t\t}\n369|\t}\n370|\treturn transitionRules, nil\n371|}\n372|\n373|// Rules returns the minimum set of rules necessary to convert a *deny-all*\n374|// cgroup to the emulated filter state (note that this is not the same as a\n375|// default cgroupv1 cgroup -- which is allow-all). This is effectively just a\n376|// wrapper around Transition() with the source emulator being an empty cgroup.\n377|func (e *emulator) Rules() ([]*devices.Rule, error) {\n378|\tdefaultCgroup := &emulator{defaultAllow: false}\n379|\treturn defaultCgroup.Transition(e)\n380|}\n381|\n382|func wrapErr(err error, text string) error {\n383|\tif err == nil {\n384|\t\treturn nil\n385|\t}\n386|\treturn fmt.Errorf(text+": %w", err)\n387|}\n'
