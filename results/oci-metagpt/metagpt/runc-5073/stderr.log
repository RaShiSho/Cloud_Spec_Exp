882|func setupDevSymlinks(rootfs string) error {
883|	// In theory, these should be links to /proc/thread-self, but systems
884|	// expect these to be /proc/self and this matches how most distributions
885|	// work.
886|	links := [][2]string{
887|		{"/proc/self/fd", "/dev/fd"},
888|		{"/proc/self/fd/0", "/dev/stdin"},
889|		{"/proc/self/fd/1", "/dev/stdout"},
890|		{"/proc/self/fd/2", "/dev/stderr"},
