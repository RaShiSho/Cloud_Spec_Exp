rams := make([]*ebpf.Program, 0, len(progIds))\n063|\t\tfor _, progId := range progIds {\n064|\t\t\tprogram, err := ebpf.NewProgramFromID(ebpf.ProgramID(progId))\n065|\t\t\tif err != nil {\n066|\t\t\t\t// We skip over programs that give us -EACCES or -EPERM. This\n067|\t\t\t\t// is necessary because there may be BPF programs that have\n068|\t\t\t\t// been attached (such as with --systemd-cgroup) which have an\n069|\t\t\t\t// LSM label that blocks us from interacting with the program.\n070|\t\t\t\t//\n071|\t\t\t\t// Because additional BPF_CGROUP_DEVICE programs only can add\n072|\t\t\t\t// restrictions, there\'s no real issue with just ignoring these\n073|\t\t\t\t// programs (and stops runc from breaking on distributions with\n074|\t\t\t\t// very strict SELinux policies).\n075|\t\t\t\tif errors.Is(err, os.ErrPermission) {\n076|\t\t\t\t\tlogrus.Debugf("ignoring existing CGROUP_DEVICE program (prog_id=%v) which cannot be accessed by runc -- likely due to LSM policy: %v", progId, err)\n077|\t\t\t\t\tcontinue\n078|\t\t\t\t}\n079|\t\t\t\treturn nil, fmt.Errorf("cannot fetch program from id: %w", err)\n080|\t\t\t}\n081|\t\t\tprograms = append(programs, program)\n082|\t\t}\n083|\t\truntime.KeepAlive(progIds)\n084|\t\treturn programs, nil\n085|\t}\n086|\n087|\treturn nil, errors.New("could not get complete list of CGROUP_DEVICE programs")\n088|}\n089|\n090|var (\n091|\thaveBpfProgReplaceBool bool\n092|\thaveBpfProgReplaceOnce sync.Once\n093|)\n094|\n095|// Loosely based on the BPF_F_REPLACE support check in\n096|// https://github.com/cilium/ebpf/blob/v0.6.0/link/syscalls.go.\n097|//\n098|// TODO: move this logic to cilium/ebpf\n099|func haveBpfProgReplace() bool {\n100|\thaveBpfProgReplaceOnce.Do(func() {\n101|\t\tprog, err := ebpf.NewProgram(&ebpf.ProgramSpec{\n102|\t\t\tType:    ebpf.CGroupDevice,\n103|\t\t\tLicense: "MIT",\n104|\t\t\tInstructions: asm.Instructions{\n105|\t\t\t\tasm.Mov.Imm(asm.R0, 0),\n106|\t\t\t\tasm.Return(),\n107|\t\t\t},\n108|\t\t})\n109|\t\tif err !=