564|static int
565|write_devices_resources_v2 (int dirfd, runtime_spec_schema_defs_linux_device_cgroup **devs, size_t devs_len,
566|                            libcrun_error_t *err)
567|{
568|  int ret;
569|  size_t i;
570|  bool can_skip = true;
571|
572|  ret = write_devices_resources_v2_internal (dirfd, devs, devs_len, err);
573|  if (LIKELY (ret == 0))
574|    return 0;
575|
576|  /* If writing the resources ebpf failed, check if it is fine to ignore the error.  */
577|  for (i = 0; i < devs_len; i++)
578|    {
579|      if (devs[i]->allow_present && ! devs[i]->allow)
580|        {
581|          can_skip = false;
582|          break;
583|        }
584|    }
585|
586|  if (! can_skip)
587|    {
588|      libcrun_error_t tmp_err = NULL;
589|      int rootless;
590|
591|      rootless = is_rootless (&tmp_err);
592|      if (UNLIKELY (rootless < 0))
593|        {
594|          crun_error_release (err);
595|          *err = tmp_err;
596|          return ret;
597|        }
598|      if (rootless)
599|        can_skip = true;
600|    }
601|
602|  if (can_skip)
603|    {
604|      crun_error_release (err);
605|      ret = 0;
606|    }
607|
608|  return ret;
