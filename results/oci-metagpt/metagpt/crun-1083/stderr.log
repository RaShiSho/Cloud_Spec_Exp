202|static int
203|write_blkio_resources (int dirfd, bool cgroup2, runtime_spec_schema_config_linux_resources_block_io *blkio,
204|                       libcrun_error_t *err)
205|{
206|  char fmt_buf[128];
207|  size_t len;
208|  int ret;
209|
210|  if (blkio->weight)
211|    {
212|      uint32_t val = blkio->weight;
213|
214|      len = sprintf (fmt_buf, "%" PRIu32, val);
215|      if (! cgroup2)
216|        {
217|          ret = write_cgroup_file (dirfd, "blkio.weight", fmt_buf, len, err);
218|          if (UNLIKELY (ret < 0))
219|            return ret;
220|        }
221|      else
222|        {
223|          ret = write_cgroup_file (dirfd, "io.bfq.weight", fmt_buf, len, err);
224|          if (UNLIKELY (ret < 0))
225|            {
226|              if (crun_error_get_errno (err) == ENOENT)
227|                {
228|                  crun_error_release (err);
229|
230|                  /* convert linearly from [10-1000] to [1-10000] */
231|                  val = 1 + (val - 10) * 9999 / 990;
232|
233|                  len = sprintf (fmt_buf, "%" PRIu32, val);
234|
235|                  ret = write_cgroup_file (dirfd, "io.weight", fmt_buf, len, err);
236|                }
237|
238|              if (UNLIKELY (ret < 0))
239|                return ret;
240|            }
241|        }
242|    }
243|  if (blkio->leaf_weight)
244|    {
245|      if (cgroup2)
246|        return crun_make_error (err, 0, "cannot set leaf_weight with cgroupv2");
247|      len = sprintf (fmt_buf, "%d", blkio->leaf_weight);
248|      ret = write_cgroup_file (dirfd, "blkio.leaf_weight", fmt_buf, len, err);
249|      if (UNLIKELY (ret < 0))
250|        return ret;
251|    }
252|  if (blkio->weight_device_len)
253|    {
254|      if (cgroup2)
255|        {
256|          cleanup_close int wfd = -1;
257|          size_t i;
258|
259|          wfd = openat (dirfd, "io.bfq.weight", O_WRONLY);
260|          if (UNLIKELY (wfd < 0))
261|            return crun_make_error (err, errno, "open io.weight");
262|          for (i = 0; i < blkio->weight_device_len; i++)
263|            {
264|              uint32_t w = blkio->weight_device[i]->weight;
265|
266|              len = sprintf (fmt_buf, "%" PRIu64 ":%" PRIu64 " %i\n", blkio->weight_device[i]->major,
267|                             blkio->weight_device[i]->minor, w);
268|              ret = TEMP_FAILURE_RETRY (write (wfd, fmt_buf, len));
269|              if (UNLIKELY (ret < 0))
270|                return crun_make_error (err, errno, "write io.weight");
271|
272|              /* Ignore blkio->weight_device[i]->leaf_weight.  */
273|            }
274|        }
275|      else
276|        {
277|          cleanup_close int w_device_fd = -1;
278|          cleanup_close int w_leafdevice_fd = -1;
279|          size_t i;
280|
281|          w_device_fd = openat (dirfd, "blkio.weight_device", O_WRONLY);
282|          if (UNLIKELY (w_device_fd < 0))
283|            return crun_make_error (err, errno, "open blkio.weight_device");
284|
285|          w_leafdevice_fd = openat (dirfd, "blkio.leaf_weight_device", O_WRONLY);
286|          if (UNLIKELY (w_leafdevice_fd < 0))
287|            return crun_make_error (err, errno, "open blkio.leaf_weight_device");
288|
289|          for (i = 0; i < blkio->weight_device_len; i++)
290|            {
291|              len = sprintf (fmt_buf, "%" PRIu64 ":%" PRIu64 " %" PRIu16 "\n", blkio->weight_device[i]->major,
292|                             blkio->weight_device[i]->minor, blkio->weight_device[i]->weight);
293|              ret = TEMP_FAILURE_RETRY (write (w_device_fd, fmt_buf, len));
294|              if (UNLIKELY (ret < 0))
295|                return crun_make_error (err, errno, "write blkio.weight_device");
296|
297|              len = sprintf (fmt_buf, "%" PRIu64 ":%" PRIu64 " %" PRIu16 "\n", blkio->weight_device[i]->major,
298|                             blkio->weight_device[i]->minor, blkio->weight_device[i]->leaf_weight);
299|              ret = TEMP_FAILURE_RETRY (write (w_leafdevice_fd, fmt_buf, len));
300|              if (UNLIKELY (ret < 0))
301|                return crun_make_error (err, errno, "write blkio.leaf_weight_device");
302|            }
303|        }
304|    }
305|  if (cgroup2)
306|    {
307|      cleanup_close int wfd = -1;
308|      const char *name = "io.max";
309|
310|      wfd = openat (dirfd, name, O_WRONLY);
311|      if (UNLIKELY (wfd < 0))
312|        {
313|          ret = crun_make_error (err, errno, "open `%s`", name);
314|          return check_cgroup_v2_controller_available_wrapper (ret, dirfd, name, err);
315|        }
316|
317|      ret = write_blkio_v2_resources_throttling (wfd, "rbps", (throttling_s **) blkio->throttle_read_bps_device,
318|                                                 blkio->throttle_read_bps_device_len, err);
319|      if (UNLIKELY (ret < 0))
320|        return ret;
321|
322|      ret = write_blkio_v2_resources_throttling (wfd, "wbps", (throttling_s **) blkio->throttle_write_bps_device,
323|                                                 blkio->throttle_write_bps_device_len, err);
324|      if (UNLIKELY (ret < 0))
325|        return ret;
326|
327|      ret = write_blkio_v2_resources_throttling (wfd, "riops", (throttling_s **) blkio->throttle_read_iops_device,
328|                                                 blkio->throttle_read_iops_device_len, err);
