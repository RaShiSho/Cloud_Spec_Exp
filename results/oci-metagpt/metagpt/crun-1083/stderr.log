667|static int
668|write_memory_swap (int dirfd, bool cgroup2, runtime_spec_schema_config_linux_resources_memory *memory,
669|                   libcrun_error_t *err)
670|{
671|  int ret;
672|  int64_t swap;
673|  char swap_buf[32];
674|  size_t swap_buf_len;
675|  const char *fname = cgroup2 ? "memory.swap.max" : "memory.memsw.limit_in_bytes";
676|
677|  if (! memory->swap_present)
678|    return 0;
679|
680|  swap = memory->swap;
681|  if (cgroup2 && memory->swap != -1)
682|    {
683|      if (! memory->limit_present)
684|        return crun_make_error (err, 0, "cannot set swap limit without the memory limit");
685|      if (memory->swap < memory->limit)
686|        return crun_make_error (err, 0, "cannot set memory+swap limit less than the memory limit");
687|
688|      swap -= memory->limit;
689|    }
690|
691|  swap_buf_len = cg_itoa (swap_buf, swap, cgroup2);
692|
693|  ret = write_cgroup_file (dirfd, fname, swap_buf, swap_buf_len, err);
694|  if (ret >= 0)
695|    return ret;
696|
697|  /* If swap is not enabled, ignore the error.  */
698|  if (crun_error_get_errno (err) == ENOENT)
699|    {
700|      crun_error_release (err);
701|      return 0;
702|    }
703|
704|  return ret;
705|}
