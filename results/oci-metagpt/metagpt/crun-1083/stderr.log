047|static int
048|is_rwm (const char *str, libcrun_error_t *err)
049|{
050|  const char *it;
051|  bool r = false;
052|  bool w = false;
053|  bool m = false;
054|
055|  for (it = str; *it; it++)
056|    switch (*it)
057|      {
058|      case 'r':
059|        r = true;
060|        break;
061|
062|      case 'w':
063|        w = true;
064|        break;
065|
066|      case 'm':
067|        m = true;
068|        break;
069|
070|      default:
071|        return crun_make_error (err, 0, "invalid mode specified `%s`", str);
072|      }
073|
074|  return r && w && m ? 1 : 0;
