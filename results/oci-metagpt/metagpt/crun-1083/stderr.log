707|static int
708|write_memory_resources (int dirfd, bool cgroup2, runtime_spec_schema_config_linux_resources_memory *memory,
709|                        libcrun_error_t *err)
710|{
711|  size_t len;
712|  int ret;
713|  char fmt_buf[32];
714|  bool memory_limits_written = false;
715|
716|  if (cgroup2 && memory->check_before_update_present && memory->check_before_update)
717|    {
718|      cleanup_free char *swap_current = NULL;
719|      cleanup_free char *current = NULL;
720|      uint64_t limit = 0;
721|      uint64_t val, val_swap;
722|      int ret;
723|
724|      ret = read_all_file_at (dirfd, "memory.current", &current, NULL, err);
725|      if (UNLIKELY (ret < 0))
726|        return ret;
727|
728|      ret = read_all_file_at (dirfd, "memory.swap.current", &swap_current, NULL, err);
729|      if (UNLIKELY (ret < 0))
730|        return ret;
731|
732|      errno = 0;
733|      val = strtoll (current, NULL, 10);
734|      if (UNLIKELY (errno))
735|        return crun_make_error (err, errno, "parse memory.current");
736|
737|      val_swap = strtoll (swap_current, NULL, 10);
738|      if (UNLIKELY (errno))
739|        return crun_make_error (err, errno, "parse memory.swap.current");
740|
741|      if (memory->limit_present && memory->limit >= 0)
742|        limit = memory->limit;
743|      if (memory->swap_present && memory->swap >= 0)
744|        limit += memory->swap;
745|
746|      if (limit <= val + val_swap)
747|        return crun_make_error (err, 0, "cannot set the memory limit lower than its current usage");
748|    }
749|
750|  if (memory->limit_present)
751|    {
752|      ret = write_memory (dirfd, cgroup2, memory, err);
753|      if (ret >= 0)
754|        memory_limits_written = true;
755|      else
756|        {
757|          if (cgroup2 || crun_error_get_errno (err) != EINVAL)
758|            return ret;
759|
760|          /*
761|            If we get an EINVAL error on cgroup v1 we reverse
762|            the order we write the memory limit and the swap.
763|            Attempt to write again the memory limit once the memory
764|            swap is written.
765|          */
766|          crun_error_release (err);
767|        }
768|    }
769|
770|  ret = write_memory_swap (dirfd, cgroup2, memory, err);
771|  if (UNLIKELY (ret < 0))
772|    return ret;
773|
774|  if (memory->limit_present && ! memory_limits_written)
775|    {
776|      ret = write_memory (dirfd, cgroup2, memory, err);
777|      if (UNLIKELY (ret < 0))
778|        return ret;
779|    }
780|
781|  if (memory->kernel_present)
782|    {
783|      if (cgroup2)
784|        return crun_make_error (err, 0, "cannot set kernel memory with cgroupv2");
785|
786|      len = sprintf (fmt_buf, "%" PRIu64, memory->kernel);
787|      ret = write_cgroup_file (dirfd, "memory.kmem.limit_in_bytes", fmt_buf, len, err);
788|      if (UNLIKELY (ret < 0))
789|        return ret;
790|    }
791|
792|  // allows users set use_hierarchy as 0 when defined as false in spec.
793|  // if use_hierarchy is not defined in spec value defaults to 1 (True).
794|  // Note: users can only toggle use_hierarchy if the parent cgroup has use_hierarchy configured as 0.
795|  if (memory->use_hierarchy_present)
796|    {
797|      if (cgroup2)
798|        return crun_make_error (err, 0, "cannot set useHierarchy memory with cgroupv2");
799|
800|      ret = write_cgroup_file (dirfd, "memory.use_hierarchy", (memory->use_hierarchy) ? "1" : "0", 1, err);
801|      if (UNLIKELY (ret < 0))
802|        return ret;
803|    }
804|
805|  if (memory->reservation_present)
806|    {
807|      len = sprintf (fmt_buf, "%" PRIu64, memory->reservation);
808|      ret = write_file_and_check_controllers_at (cgroup2, dirfd, cgroup2 ? "memory.low" : "memory.soft_limit_in_bytes",
809|                                                 fmt_buf, len, err);
810|      if (UNLIKELY (ret < 0))
811|        return ret;
812|    }
813|  if (memory->disable_oom_killer)
814|    {
815|      if (cgroup2)
816|        return crun_make_error (err, 0, "cannot disable OOM killer with cgroupv2");
817|
818|      ret = write_cgroup_file (dirfd, "memory.oom_control", "1", 1, err);
819|      if (UNLIKELY (ret < 0))
820|        return ret;
821|    }
822|  if (memory->kernel_tcp_present)
823|    {
824|      if (cgroup2)
825|        return crun_make_error (err, 0, "cannot set kernel TCP with cgroupv2");
826|
827|      len = sprintf (fmt_buf, "%" PRIu64, memory->kernel_tcp);
828|      ret = write_cgroup_file (dirfd, "memory.kmem.tcp.limit_in_bytes", fmt_buf, len, err);
829|      if (UNLIKELY (ret < 0))
830|        return ret;
831|    }
832|  if (memory->swappiness_present)
833|    {
834|      if (cgroup2)
835|        return crun_make_error (err, 0, "cannot set memory swappiness with cgroupv2");
836|
837|      len = sprintf (fmt_buf, "%" PRIu64, memory->swappiness);
838|      ret = write_cgroup_file (dirfd, "memory.swappiness", fmt_buf, len, err);
839|      if (UNLIKELY (ret < 0))
840|        return ret;
841|    }
842|
843|  return 0;
