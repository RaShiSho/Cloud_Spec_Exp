    f"cd {repo_path} && grep -rn 'cpu.shares\\|cfs_quota\\|cpu.weight' src/ --include='*.c' --include='*.h'",
    shell=True, capture_output=True, text=True
)
print("\n=== Lines with cpu.shares, cfs_quota, cpu.weight ===")
print(grep_result.stdout)

print("\n\n================== FINAL ANALYSIS AND SUMMARY ==================")
print("Issue: crun-876 – Support cgroupv1 cpu.idle setting")
print("GitHub: https://github.com/containers/crun/issues/876")
print("The OCI config sets 'linux.resources.cpu.idle = 1' in buggy_config.json.")
print("Expected behavior: runtime should write '1' to the cgroup v1 cpu.idle file.")
print("Currently, crun does not support cpu.idle on cgroup v1 (only v2 may have it).")
print()
print("Source files found in src/ that contain cgroup CPU settings:")
print(result.stdout if result.stdout else "Need to inspect further.")
print()
print("Based on common crun structure, the key files to modify are:")
print("1. src/libcrun/cgroup.c or src/libcrun/cgroup_resources.c – main cgroup handler")
print("   - Add a function to parse 'idle' from the OCI CPU resources struct.")
print("   - Call a helper to write the idle value to the cgroup filesystem.")
print("2. src/libcrun/cgroup_v1.c (if it exists) – cgroup v1 specific writes")
print("   - Add writing to /sys/fs/cgroup/cpu/<container>/cpu.idle or /sys/fs/cgroup/cpu,cpuacct/<container>/cpu.idle")
print("   - Similar to existing code that writes cpu.shares to cpu.shares file.")
print("3. Any header file that defines the cgroup resources structure (e.g., cgroup.h)")
print("   - Ensure the cpu.idle field is included in the internal representation.")
print()
print("The fix should mirror how cpu.shares, cpu.cfs_period_us, etc., are handled for cgroup v1.")
print("Specifically, we need to:")
print("- Parse the 'idle' integer from the OCI LinuxCPU struct (already in oci-spec) into internal state.")
print("- When creating/updating cgroup v1, write the idle value to the cpu.idle file if non-zero or if explicitly set.")
print("- Handle the case where the file may not exist (older kernels) gracefully.")
print("================================================================")
