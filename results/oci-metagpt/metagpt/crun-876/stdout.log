paths_to_check = [
    f"{repo_path}/src/libcrun/cgroup.c",
    f"{repo_path}/src/libcrun/cgroup_resources.c",
    f"{repo_path}/src/libcrun/cgroup_v1.c",
    f"{repo_path}/src/libcrun/cgroup_v2.c",
    f"{repo_path}/src/libcrun/cgroup_utils.c",
]

