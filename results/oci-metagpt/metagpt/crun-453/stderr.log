074|static unsigned long
075|get_seccomp_operator (const char *name, libcrun_error_t *err)
076|{
077|  if (strcmp (name, "SCMP_CMP_NE") == 0)
078|    return SCMP_CMP_NE;
079|  if (strcmp (name, "SCMP_CMP_LT") == 0)
080|    return SCMP_CMP_LT;
081|  if (strcmp (name, "SCMP_CMP_LE") == 0)
082|    return SCMP_CMP_LE;
083|  if (strcmp (name, "SCMP_CMP_EQ") == 0)
084|    return SCMP_CMP_EQ;
085|  if (strcmp (name, "SCMP_CMP_GE") == 0)
086|    return SCMP_CMP_GE;
087|  if (strcmp (name, "SCMP_CMP_GT") == 0)
088|    return SCMP_CMP_GT;
089|  if (strcmp (name, "SCMP_CMP_MASKED_EQ") == 0)
090|    return SCMP_CMP_MASKED_EQ;
091|
092|  crun_make_error (err, 0, "seccomp get operator", name);
093|  return 0;
094|}
