096|static unsigned long long
097|get_seccomp_action (const char *name, int errno_ret, libcrun_error_t *err)
098|{
099|  const char *p;
100|
101|  p = name;
102|  if (strncmp (p, "SCMP_ACT_", 9))
103|    goto fail;
104|
105|  p += 9;
106|
107|  if (strcmp (p, "ALLOW") == 0)
108|    return SCMP_ACT_ALLOW;
109|  else if (strcmp (p, "ERRNO") == 0)
110|    return SCMP_ACT_ERRNO (errno_ret);
111|  else if (strcmp (p, "KILL") == 0)
112|    return SCMP_ACT_KILL;
113|  else if (strcmp (p, "TRAP") == 0)
114|    return SCMP_ACT_TRAP;
115|  else if (strcmp (p, "TRACE") == 0)
116|    return SCMP_ACT_TRACE (errno_ret);
117|#ifdef SCMP_ACT_KILL_PROCESS
118|  else if (strcmp (p, "KILL_PROCESS") == 0)
119|    return SCMP_ACT_KILL_PROCESS;
120|#endif
121|
122| fail:
123|  crun_make_error (err, 0, "seccomp get action", name);
124|  return 0;
125|}
