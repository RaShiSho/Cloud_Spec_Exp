146|int
147|libcrun_apply_seccomp (int infd, char **seccomp_flags, size_t seccomp_flags_len, libcrun_error_t *err)
148|{
149|  int ret;
150|  struct sock_fprog seccomp_filter;
151|  cleanup_free char *bpf = NULL;
152|  unsigned int flags = 0;
153|  size_t len;
154|
155|  if (infd < 0)
156|    return 0;
157|
158|  if (UNLIKELY (lseek (infd, 0, SEEK_SET) == (off_t) -1))
159|    return crun_make_error (err, errno, "lseek");
160|
161|
162|  /* if no seccomp flag was specified use a sane default.  */
163|  if (seccomp_flags == NULL)
164|    flags = SECCOMP_FILTER_FLAG_LOG|SECCOMP_FILTER_FLAG_SPEC_ALLOW;
165|  else
166|    {
167|      size_t i = 0;
168|      for (i = 0; i < seccomp_flags_len; i++)
169|        {
170|          if (strcmp (seccomp_flags[i], "SECCOMP_FILTER_FLAG_TSYNC") == 0)
171|              flags |= SECCOMP_FILTER_FLAG_TSYNC;
172|          else if (strcmp (seccomp_flags[i], "SECCOMP_FILTER_FLAG_SPEC_ALLOW") == 0)
173|            flags |= SECCOMP_FILTER_FLAG_SPEC_ALLOW;
174|          else if (strcmp (seccomp_flags[i], "SECCOMP_FILTER_FLAG_LOG") == 0)
175|            flags |= SECCOMP_FILTER_FLAG_LOG;
176|          else
177|            return crun_make_error (err, 0, "unknown seccomp option %s", seccomp_flags[i]);
178|        }
179|    }
180|
181|  ret = read_all_fd (infd, "seccomp.bpf", &bpf, &len, err);
182|  if (UNLIKELY (ret < 0))
183|    return ret;
184|
185|  seccomp_filter.len = len / 8;
186|  seccomp_filter.filter = (struct sock_filter *) bpf;
187|
188|  ret = syscall_seccomp (SECCOMP_SET_MODE_FILTER, flags, &seccomp_filter);
189|  if (UNLIKELY (ret < 0))
190|    {
191|      /* If any of the flags is not supported, try again without specifying them:  */
192|      if (errno == EINVAL)
193|        ret = syscall_seccomp (SECCOMP_SET_MODE_FILTER, 0, &seccomp_filter);
194|      if (UNLIKELY (ret < 0))
195|        return crun_make_error (err, errno, "seccomp (SECCOMP_SET_MODE_FILTER)");
196|    }
197|
198|  return 0;
